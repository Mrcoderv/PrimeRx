@page
@{
    ViewData["Title"] = "Forgot Password Confirmation";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white text-center py-3">
                <h5 class="mb-0"><i class="bi bi-check-circle me-2"></i>Check Your Email</h5>
            </div>
            <div class="card-body p-4 text-center">
                <i class="bi bi-envelope-check text-success" style="font-size: 3rem;"></i>
                <p class="mt-3 mb-0">
                    If an account with that email exists, we have sent a 6-digit OTP.
                </p>
                <p class="mt-2">
                    Please check your email and enter the OTP to reset your password.
                </p>
                <a asp-page="./Login" class="btn btn-primary mt-3">
                    <i class="bi bi-box-arrow-in-right me-1"></i>Back to Login
                </a>
            </div>
        </div>
    </div>
</div>
