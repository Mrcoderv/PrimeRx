@page
@model PrimeRx.Areas.Identity.Pages.Account.VerifyOtpModel
@{
    ViewData["Title"] = "Verify OTP";
}

<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white text-center py-3">
                <h5 class="mb-0"><i class="bi bi-shield-check me-2"></i>Verify OTP</h5>
            </div>
            <div class="card-body p-4">
                <p class="text-muted text-center small mb-4">
                    Enter the 6-digit code sent to <strong>@Model.Input.Email</strong>
                </p>
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
                    <input type="hidden" asp-for="Input.Email" />

                    <div class="mb-3">
                        <label asp-for="Input.OtpCode" class="form-label fw-semibold"></label>
                        <input asp-for="Input.OtpCode" class="form-control text-center"
                               autocomplete="one-time-code" inputmode="numeric"
                               maxlength="6" placeholder="000000"
                               style="font-size:1.5rem;letter-spacing:0.5em;font-weight:700;" />
                        <span asp-validation-for="Input.OtpCode" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="w-100 btn btn-primary">
                        <i class="bi bi-check-circle me-2"></i>Verify OTP
                    </button>
                </form>
                <div class="mt-3 text-center">
                    <a asp-page="./ForgotPassword" class="text-decoration-none small">
                        <i class="bi bi-arrow-left me-1"></i>Request a new OTP
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('Input_OtpCode')?.addEventListener('input', function () {
            this.value = this.value.replace(/\D/g, '').slice(0, 6);
        });
    </script>
}
