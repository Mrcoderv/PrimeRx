@page
@using PrimeRx.Models
@model PrimeRx.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="dash-container">
    <div class="dash-header">
        <div>
            <h1 class="dash-title">Dashboard</h1>
            <p class="dash-subtitle">Pharmacy business overview</p>
        </div>
        <a asp-page="/Billing/Index" class="dash-btn-primary">
            <i class="bi bi-plus-lg"></i> New Bill
        </a>
    </div>

    @* ── Global Search Bar ── *@
    <div class="dash-search-bar" data-search-trigger>
        <div class="dash-search-inner">
            <i class="bi bi-search dash-search-icon"></i>
            <span class="dash-search-text">Search features, pages...</span>
            <span class="dash-search-shortcut"><kbd>Ctrl</kbd>+<kbd>K</kbd></span>
        </div>
    </div>

    @* ── Stat Cards Row 1: Today ── *@
    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-icon icon-sales">
                <i class="bi bi-graph-up-arrow"></i>
            </div>
            <div class="stat-body">
                <div class="stat-label">Today's Sales</div>
                <div class="stat-value">@(Model.Summary.TodaySales.ToRs())</div>
                <div class="stat-footer">@Model.Summary.TodayBills bills</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon icon-discount">
                <i class="bi bi-tag"></i>
            </div>
            <div class="stat-body">
                <div class="stat-label">Discount Today</div>
                <div class="stat-value">@(Model.Summary.TodayDiscount.ToRs())</div>
                <div class="stat-footer">given on today's bills</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon icon-expense">
                <i class="bi bi-wallet2"></i>
            </div>
            <div class="stat-body">
                <div class="stat-label">Today's Expense</div>
                <div class="stat-value">@(Model.Summary.TodayExpenses.ToRs())</div>
                <div class="stat-footer">operational costs</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon icon-profit">
                <i class="bi bi-piggy-bank"></i>
            </div>
            <div class="stat-body">
                <div class="stat-label">Today's Profit</div>
                <div class="stat-value">@(Model.Summary.TodayProfit.ToRs())</div>
                <div class="stat-footer">net earnings</div>
            </div>
        </div>
    </div>

    @* ── Stat Cards Row 2: Monthly ── *@
    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-icon icon-sales">
                <i class="bi bi-calendar-check"></i>
            </div>
            <div class="stat-body">
                <div class="stat-label">Monthly Sales</div>
                <div class="stat-value">@(Model.Summary.MonthSales.ToRs())</div>
                <div class="stat-footer">@Model.Summary.MonthBills bills this month</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon icon-discount">
                <i class="bi bi-percent"></i>
            </div>
            <div class="stat-body">
                <div class="stat-label">Monthly Discount</div>
                <div class="stat-value">@(Model.Summary.MonthDiscount.ToRs())</div>
                <div class="stat-footer">across @Model.Summary.MonthBills bills</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon icon-expense">
                <i class="bi bi-cash-stack"></i>
            </div>
            <div class="stat-body">
                <div class="stat-label">Monthly Expenses</div>
                <div class="stat-value">@(Model.Summary.MonthExpenses.ToRs())</div>
                <div class="stat-footer">this month</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon icon-profit">
                <i class="bi bi-graph-up"></i>
            </div>
            <div class="stat-body">
                <div class="stat-label">Monthly Profit</div>
                <div class="stat-value">@(Model.Summary.MonthProfit.ToRs())</div>
                <div class="stat-footer">net earnings</div>
            </div>
        </div>
    </div>

    @* ── Charts Row ── *@
    <div class="charts-grid">
        <div class="dash-card">
            <div class="dash-card-header">
                <h5><i class="bi bi-activity"></i> Sales Trend (7 Days)</h5>
            </div>
            <div class="dash-card-body">
                <canvas id="dashboardSalesChart" height="100"></canvas>
                <div id="dashSalesEmpty" class="chart-empty d-none">No sales data for the last 7 days.</div>
            </div>
        </div>
        <div class="dash-card">
            <div class="dash-card-header">
                <h5><i class="bi bi-pie-chart"></i> Top Medicines (30 Days)</h5>
            </div>
            <div class="dash-card-body">
                <canvas id="topMedicinesChart" height="180"></canvas>
                <div id="dashMedEmpty" class="chart-empty d-none">No medicine sales data yet.</div>
            </div>
        </div>
    </div>

    @* ── Bottom Row: Tables + Quick Actions ── *@
    <div class="bottom-grid">
        @* Recent Bills *@
        <div class="dash-card">
            <div class="dash-card-header d-flex justify-content-between align-items-center">
                <h5><i class="bi bi-receipt"></i> Recent Bills</h5>
                <a asp-page="/Billing/History" class="dash-link">View All <i class="bi bi-arrow-right"></i></a>
            </div>
            <div class="dash-table-wrap">
                <table class="dash-table">
                    <thead>
                        <tr>
                            <th>Bill #</th>
                            <th>Customer</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bill in Model.Summary.RecentBills)
                        {
                            <tr>
                                <td><strong>@bill.BillNumber</strong></td>
                                <td>@bill.CustomerName</td>
                                <td>@(bill.FinalAmount.ToRs())</td>
                                <td>
                                    <span class="badge-status @(bill.PaymentStatus == "Paid" ? "paid" : bill.PaymentStatus == "Due" ? "due" : "partial")">
                                        @bill.PaymentStatus
                                    </span>
                                </td>
                                <td>@bill.BillDate.ToString("dd-MM-yyyy")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        @* Sidebar *@
        <div class="dash-sidebar">
            @* Quick Actions *@
            <div class="dash-card">
                <div class="dash-card-header">
                    <h5><i class="bi bi-lightning"></i> Quick Actions</h5>
                </div>
                <div class="dash-card-body dash-actions">
                    <a asp-page="/Billing/Index" class="dash-action-btn primary">
                        <i class="bi bi-receipt"></i> Create Bill
                    </a>
                    <a asp-page="/Inventory/AddMedicine" class="dash-action-btn">
                        <i class="bi bi-plus-circle"></i> Add Medicine
                    </a>
                    @if (User.IsInRole(AppRoles.Admin))
                    {
                        <a asp-page="/Admin/Expenses/Create" class="dash-action-btn">
                            <i class="bi bi-cash-stack"></i> Add Expense
                        </a>
                    }
                    <a asp-page="/Due/Index" class="dash-action-btn">
                        <i class="bi bi-wallet2"></i> Due Collection
                    </a>
                    <a asp-page="/Reports/Index" class="dash-action-btn">
                        <i class="bi bi-bar-chart"></i> Reports
                    </a>
                </div>
            </div>

            @* Alerts *@
            @if (Model.Summary.LowStockCount > 0 || Model.Summary.ExpiringCount > 0 || Model.Summary.OutstandingDue > 0)
            {
                <div class="dash-card dash-alerts">
                    <div class="dash-card-header">
                        <h5><i class="bi bi-bell"></i> Alerts</h5>
                    </div>
                    <div class="dash-card-body">
                        @if (Model.Summary.OutstandingDue > 0)
                        {
                            <div class="alert-item warning">
                                <i class="bi bi-wallet2"></i>
                                <span><strong>@(Model.Summary.OutstandingDue.ToRs())</strong> due pending</span>
                            </div>
                        }
                        @if (Model.Summary.LowStockCount > 0)
                        {
                            <div class="alert-item warning">
                                <i class="bi bi-box-seam"></i>
                                <span><strong>@Model.Summary.LowStockCount</strong> low stock items</span>
                            </div>
                        }
                        @if (Model.Summary.ExpiringCount > 0)
                        {
                            <div class="alert-item danger">
                                <i class="bi bi-clock-history"></i>
                                <span><strong>@Model.Summary.ExpiringCount</strong> expiring medicines</span>
                            </div>
                        }
                        <a asp-page="/Inventory/Index" class="dash-action-btn warning w-100 text-center mt-2">
                            View Inventory
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/chart.umd.min.js" asp-append-version="true"></script>
    <script>
        const salesData = @Html.Raw(Model.SalesTrendJson);
        const topMeds = @Html.Raw(Model.MedicineChartJson);

        // ── Sales Trend Chart ──
        const salesCanvas = document.getElementById('dashboardSalesChart');
        const salesEmpty = document.getElementById('dashSalesEmpty');
        if (salesData.length === 0 || salesData.every(x => x.amount === 0)) {
            salesCanvas.classList.add('d-none');
            salesEmpty.classList.remove('d-none');
        } else {
            new Chart(salesCanvas, {
                type: 'line',
                data: {
                    labels: salesData.map(x => x.label),
                    datasets: [{
                        label: 'Sales (Rs.)',
                        data: salesData.map(x => x.amount),
                        borderColor: '#2563EB',
                        backgroundColor: 'rgba(37,99,235,0.1)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 5,
                        pointBackgroundColor: '#2563EB',
                        pointBorderColor: '#fff',
                        pointBorderWidth: 2,
                        borderWidth: 3
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#1e293b',
                            titleColor: '#fff',
                            bodyColor: '#cbd5e1',
                            padding: 12,
                            cornerRadius: 10,
                            callbacks: { label: ctx => ' Rs. ' + ctx.parsed.y.toLocaleString() }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: 'rgba(0,0,0,0.06)' },
                            ticks: { color: '#94a3b8', callback: v => 'Rs.' + v }
                        },
                        x: { grid: { display: false }, ticks: { color: '#94a3b8' } }
                    }
                }
            });
        }

        // ── Top Medicines Doughnut ──
        const medCanvas = document.getElementById('topMedicinesChart');
        const medEmpty = document.getElementById('dashMedEmpty');
        if (topMeds.length === 0) {
            medCanvas.classList.add('d-none');
            medEmpty.classList.remove('d-none');
        } else {
            new Chart(medCanvas, {
                type: 'doughnut',
                data: {
                    labels: topMeds.map(x => x.medicineName),
                    datasets: [{
                        data: topMeds.map(x => x.totalAmount),
                        backgroundColor: ['#2563EB', '#10B981', '#F59E0B', '#EF4444', '#8B5CF6'],
                        borderColor: '#fff',
                        borderWidth: 3,
                        hoverOffset: 8
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { color: '#64748b', boxWidth: 12, padding: 10, font: { size: 11 } }
                        },
                        tooltip: {
                            backgroundColor: '#1e293b',
                            padding: 12,
                            cornerRadius: 10,
                            callbacks: { label: ctx => ' Rs. ' + ctx.parsed.toLocaleString() }
                        }
                    },
                    cutout: '68%'
                }
            });
        }
    </script>
}
