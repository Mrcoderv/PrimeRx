@page
@model PrimeRx.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Business Dashboard</h1>
        <p class="page-subtitle">Real-time overview of your pharmacy operations</p>
    </div>
    <a asp-page="/Billing/Index" class="btn btn-accent btn-lg">
        <span class="me-1">+</span> New Bill
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-primary">
            <div class="stat-label">Today's Sales</div>
            <div class="stat-value">Rs. @Model.Summary.TodaySales.ToString("N0")</div>
            <div class="stat-foot">@Model.Summary.TodayBills bills today</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-info">
            <div class="stat-label">Monthly Sales</div>
            <div class="stat-value">Rs. @Model.Summary.MonthSales.ToString("N0")</div>
            <div class="stat-foot">@Model.Summary.MonthBills bills this month</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-warning">
            <div class="stat-label">Outstanding Due</div>
            <div class="stat-value">Rs. @Model.Summary.OutstandingDue.ToString("N0")</div>
            <div class="stat-foot"><a asp-page="/Due/Index" class="text-white text-decoration-underline">Collect payments</a></div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-success">
            <div class="stat-label">Active Medicines</div>
            <div class="stat-value">@Model.Summary.TotalMedicines</div>
            <div class="stat-foot">@Model.Summary.LowStockCount low stock · @Model.Summary.ExpiringCount expiring</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="panel-card h-100">
            <div class="panel-header">
                <h5>Sales Trend (Last 7 Days)</h5>
            </div>
            <div class="panel-body chart-panel">
                <canvas id="dashboardSalesChart" height="120"></canvas>
                <div id="dashSalesEmpty" class="chart-empty d-none">No sales data for the last 7 days.</div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="panel-card h-100">
            <div class="panel-header">
                <h5>Top Medicines (30 Days)</h5>
            </div>
            <div class="panel-body chart-panel">
                <canvas id="topMedicinesChart" height="200"></canvas>
                <div id="dashMedEmpty" class="chart-empty d-none">No medicine sales data yet.</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="panel-card">
            <div class="panel-header d-flex justify-content-between align-items-center">
                <h5>Recent Bills</h5>
                <a asp-page="/Billing/History" class="btn btn-sm btn-outline-light">View All</a>
            </div>
            <div class="table-responsive">
                <table class="table table-pro mb-0">
                    <thead>
                        <tr>
                            <th>Bill #</th>
                            <th>Customer</th>
                            <th>Amount</th>
                            <th>Status</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var bill in Model.Summary.RecentBills)
                        {
                            <tr>
                                <td><strong>@bill.BillNumber</strong></td>
                                <td>@bill.CustomerName</td>
                                <td>Rs. @bill.FinalAmount.ToString("N2")</td>
                                <td>
                                    <span class="badge-status @(bill.PaymentStatus == "Paid" ? "paid" : bill.PaymentStatus == "Due" ? "due" : "partial")">
                                        @bill.PaymentStatus
                                    </span>
                                </td>
                                <td>@bill.BillDate.ToString("dd-MM-yyyy HH:mm")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="panel-card mb-3">
            <div class="panel-header"><h5>Quick Actions</h5></div>
            <div class="panel-body d-grid gap-2">
                <a asp-page="/Billing/Index" class="btn btn-accent">Create Bill</a>
                <a asp-page="/Inventory/AddMedicine" class="btn btn-outline-accent">Add Medicine</a>
                <a asp-page="/Inventory/Purchase" class="btn btn-outline-accent">Purchase Entry</a>
                <a asp-page="/Due/Index" class="btn btn-outline-accent">Due Collection</a>
                <a asp-page="/Reports/Index" class="btn btn-outline-accent">Reports & Charts</a>
            </div>
        </div>
        @if (Model.Summary.LowStockCount > 0 || Model.Summary.ExpiringCount > 0)
        {
            <div class="panel-card alert-panel">
                <div class="panel-header"><h5>Alerts</h5></div>
                <div class="panel-body">
                    @if (Model.Summary.LowStockCount > 0)
                    {
                        <div class="alert-item warning">
                            <strong>@Model.Summary.LowStockCount</strong> medicines are low on stock
                        </div>
                    }
                    @if (Model.Summary.ExpiringCount > 0)
                    {
                        <div class="alert-item danger">
                            <strong>@Model.Summary.ExpiringCount</strong> medicines expiring within 90 days
                        </div>
                    }
                    <a asp-page="/Inventory/Index" class="btn btn-sm btn-warning w-100 mt-2">View Inventory</a>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        const salesData = @Html.Raw(Model.SalesTrendJson);
        const topMeds = @Html.Raw(Model.MedicineChartJson);
        const chartGrid = 'rgba(255,255,255,0.08)';
        const chartFont = '#94a3b8';

        const dashSalesCanvas = document.getElementById('dashboardSalesChart');
        const dashSalesEmpty = document.getElementById('dashSalesEmpty');
        if (salesData.length === 0 || salesData.every(x => x.amount === 0)) {
            dashSalesCanvas.classList.add('d-none');
            dashSalesEmpty.classList.remove('d-none');
        } else {
            new Chart(dashSalesCanvas, {
                type: 'line',
                data: {
                    labels: salesData.map(x => x.label),
                    datasets: [{
                        label: 'Sales (Rs.)',
                        data: salesData.map(x => x.amount),
                        borderColor: '#38bdf8',
                        backgroundColor: 'rgba(56, 189, 248, 0.15)',
                        fill: true,
                        tension: 0.4,
                        pointRadius: 4,
                        pointBackgroundColor: '#38bdf8'
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#0f2744',
                            titleColor: '#fff',
                            bodyColor: '#cbd5e1',
                            callbacks: { label: ctx => ' Rs. ' + ctx.parsed.y.toLocaleString() }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            grid: { color: chartGrid },
                            ticks: { color: chartFont, callback: v => 'Rs.' + v }
                        },
                        x: { grid: { display: false }, ticks: { color: chartFont } }
                    }
                }
            });
        }

        const dashMedCanvas = document.getElementById('topMedicinesChart');
        const dashMedEmpty = document.getElementById('dashMedEmpty');
        if (topMeds.length === 0) {
            dashMedCanvas.classList.add('d-none');
            dashMedEmpty.classList.remove('d-none');
        } else {
            new Chart(dashMedCanvas, {
                type: 'doughnut',
                data: {
                    labels: topMeds.map(x => x.medicineName),
                    datasets: [{
                        data: topMeds.map(x => x.totalAmount),
                        backgroundColor: ['#3b82f6', '#06b6d4', '#6366f1', '#8b5cf6', '#0ea5e9'],
                        borderColor: '#0f2744',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom', labels: { color: '#cbd5e1', boxWidth: 12, padding: 8, font: { size: 11 } } },
                        tooltip: {
                            backgroundColor: '#0f2744',
                            callbacks: { label: ctx => ' Rs. ' + ctx.parsed.toLocaleString() }
                        }
                    }
                }
            });
        }
    </script>
}
