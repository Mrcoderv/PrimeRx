@page
@model PrimeRx.Pages.Billing.IndexModel
@{
    ViewData["Title"] = "New Bill";
}

<div class="billing-page">
    <div class="page-header">
        <div>
            <h1 class="page-title">Point of Sale</h1>
            <p class="page-subtitle">Fast billing with medicine search and invoice generation</p>
        </div>
        <a asp-page="/Billing/History" class="btn btn-outline-accent">Bill History</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show">
            @Model.SuccessMessage
            @if (Model.LastBillId.HasValue)
            {
                <a asp-page-handler="DownloadPdf" asp-route-billId="@Model.LastBillId" class="btn btn-sm btn-success ms-2">Download PDF</a>
            }
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post" id="billingForm">
        <div class="row g-3">
            <div class="col-lg-8">
                <div class="panel-card mb-3">
                    <div class="panel-body">
                        <label class="form-label billing-label">Search Medicine</label>
                        <input type="text" id="medicineSearchText"
                               class="form-control medicine-search-input"
                               placeholder="Type medicine name or code..."
                               autocomplete="off"
                               role="combobox"
                               aria-expanded="false"
                               aria-autocomplete="list"
                               aria-controls="medicinePopup">
                        <div id="medicinePopup"
                             class="medicine-popup"
                             role="listbox"
                             style="display:none;">
                            <div class="medicine-popup-header">
                                <span style="width:55%">MEDICINE</span>
                                <span style="width:25%">RATE</span>
                                <span style="width:20%">STOCK</span>
                            </div>
                            <div class="medicine-popup-body" id="medicinePopupBody"></div>
                            <div class="medicine-popup-footer">
                                <span><kbd>&uarr;</kbd><kbd>&darr;</kbd> Navigate</span>
                                <span><kbd>Enter</kbd> Add</span>
                                <span><kbd>Esc</kbd> Close</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="panel-card">
                    <div class="panel-header">Bill Items</div>
                    <div class="table-responsive">
                        <table class="table table-pro mb-0" id="itemsTable">
                            <thead>
                                <tr>
                                    <th>Medicine</th>
                                    <th style="width:85px">Rate</th>
                                    <th style="width:70px">Qty</th>
                                    <th style="width:70px">Disc%</th>
                                    <th style="width:85px">Disc Amt</th>
                                    <th style="width:95px">Amount</th>
                                    <th style="width:36px"></th>
                                </tr>
                            </thead>
                            <tbody id="itemsBody">
                                <tr id="emptyRow">
                                    <td colspan="7" class="billing-empty-msg">Search and add medicines above</td>
                                </tr>
                            </tbody>
                            <tfoot id="tableFoot">
                                <tr class="purchase-total-row">
                                    <td colspan="5" class="text-end fw-semibold">Subtotal</td>
                                    <td class="fw-bold text-accent" id="subtotalDisplay">Rs. 0.00</td>
                                    <td></td>
                                </tr>
                                <tr class="purchase-total-row">
                                    <td colspan="5" class="text-end fw-semibold text-danger">Discount</td>
                                    <td class="fw-bold text-danger" id="discountDisplay">- Rs. 0.00</td>
                                    <td></td>
                                </tr>
                                <tr class="purchase-total-row purchase-grand-total">
                                    <td colspan="5" class="text-end fw-semibold">Net Amount</td>
                                    <td class="fw-bold text-accent" id="netTotalDisplay">Rs. 0.00</td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="panel-card billing-sidebar">
                    <div class="panel-header">Customer & Payment</div>
                    <div class="panel-body">
                        <div class="mb-3">
                            <label asp-for="Input.CustomerName" class="form-label"></label>
                            <input asp-for="Input.CustomerName" class="form-control" id="customerName" />
                            <span asp-validation-for="Input.CustomerName" class="text-danger"></span>
                        </div>

                        <div class="payment-method-section mb-3">
                            <label class="form-label payment-method-label">
                                <i class="bi bi-credit-card me-1"></i>Payment Method
                            </label>
                            <select asp-for="Input.PaymentMethod" class="form-select d-none" id="paymentMethod">
                                <option value="Cash">Cash</option>
                                <option value="Online">Online / Card</option>
                                <option value="Due">Due</option>
                            </select>
                            <div class="payment-method-group" id="paymentMethodGroup">
                                <button type="button" class="payment-method-btn" data-value="Cash">
                                    <i class="bi bi-cash-coin"></i>
                                    <span>Cash</span>
                                </button>
                                <button type="button" class="payment-method-btn" data-value="Online">
                                    <i class="bi bi-credit-card-2-front"></i>
                                    <span>Online / Card</span>
                                </button>
                                <button type="button" class="payment-method-btn" data-value="Due">
                                    <i class="bi bi-journal-text"></i>
                                    <span>Due</span>
                                </button>
                            </div>
                        </div>

                        <div class="mb-3" id="customerPhoneGroup">
                            <label asp-for="Input.CustomerPhone" class="form-label">
                                <i class="bi bi-telephone me-1"></i>Customer Phone
                            </label>
                            <input asp-for="Input.CustomerPhone" class="form-control" id="customerPhone" />
                            <span asp-validation-for="Input.CustomerPhone" class="text-danger"></span>
                            <small class="text-muted" id="customerPhoneHint">Required when payment is Due</small>
                        </div>

                        <hr class="billing-divider" />
                        <div class="billing-total-row"><span>Subtotal</span><span id="sidebarSubtotal">Rs. 0.00</span></div>
                        <div class="billing-total-row text-danger"><span>Discount</span><span id="sidebarDiscount">- Rs. 0.00</span></div>
                        <div class="billing-total-row billing-total-final"><span>Net Amount</span><span id="sidebarNetTotal">Rs. 0.00</span></div>

                        <input type="hidden" asp-for="Input.ItemsJson" id="itemsJson" />
                        <button type="submit" class="btn btn-accent btn-lg w-100 mt-3" id="generateBtn" disabled>Generate Bill</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Floating Calculator -->
<div id="floatingCalc" class="floating-calc" style="display:none">
    <div class="calc-grid">
        <button type="button" class="calc-btn" data-calc="7">7</button>
        <button type="button" class="calc-btn" data-calc="8">8</button>
        <button type="button" class="calc-btn" data-calc="9">9</button>
        <button type="button" class="calc-btn calc-clear" data-calc="C">C</button>
        <button type="button" class="calc-btn" data-calc="4">4</button>
        <button type="button" class="calc-btn" data-calc="5">5</button>
        <button type="button" class="calc-btn" data-calc="6">6</button>
        <button type="button" class="calc-btn calc-back" data-calc="&#x232B;">&#x232B;</button>
        <button type="button" class="calc-btn" data-calc="1">1</button>
        <button type="button" class="calc-btn" data-calc="2">2</button>
        <button type="button" class="calc-btn" data-calc="3">3</button>
        <button type="button" class="calc-btn calc-enter" data-calc="Enter">Enter</button>
        <button type="button" class="calc-btn" data-calc="0">0</button>
        <button type="button" class="calc-btn" data-calc=".">.</button>
        <button type="button" class="calc-btn calc-plus" data-calc="+">+</button>
        <button type="button" class="calc-btn calc-minus" data-calc="-">-</button>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/billing.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/purchase.css" asp-append-version="true" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/billing.js" asp-append-version="true"></script>
}
