@page "{id:int}"
@model PrimeRx.Pages.Billing.EditModel
@{
    ViewData["Title"] = "Edit Bill";
}

<div class="billing-page">
    <div class="page-header">
        <div>
            <h1 class="page-title">Edit Bill</h1>
            <p class="page-subtitle">@Model.Bill?.BillNumber — @Model.Bill?.BillDate.ToString("dd-MM-yyyy HH:mm")</p>
        </div>
        <a asp-page="/Billing/History" class="btn btn-outline-accent">Back to History</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @if (Model.Bill?.Status == "Cancelled")
    {
        <div class="alert alert-warning">This bill was cancelled and cannot be edited.</div>
    }
    else
    {
    <form method="post" id="billingForm">
        <input type="hidden" name="id" value="@Model.Bill!.Id" />
        <div class="row g-3">
            <div class="col-lg-8">
                <div class="panel-card mb-3">
                    <div class="panel-body">
                        <label class="form-label billing-label">Search Medicine</label>
                        <input type="text" id="medicineSearchText"
                               class="form-control medicine-search-input"
                               placeholder="Type medicine name or code..."
                               autocomplete="off"
                               role="combobox"
                               aria-expanded="false"
                               aria-autocomplete="list"
                               aria-controls="medicinePopup">
                        <div id="medicinePopup"
                             class="medicine-popup"
                             role="listbox"
                             style="display:none;">
                            <div class="medicine-popup-header">
                                <span class="mpc-name">Name</span>
                                <span class="mpc-batch">Batch</span>
                                <span class="mpc-stock">Stock</span>
                                <span class="mpc-rate">Rate</span>
                            </div>
                            <div class="medicine-popup-body" id="medicinePopupBody"></div>
                            <div class="medicine-popup-footer">
                                <span><kbd>↑</kbd><kbd>↓</kbd> Navigate</span>
                                <span><kbd>Enter</kbd> Add</span>
                                <span><kbd>Esc</kbd> Close</span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="panel-card">
                    <div class="panel-header">Bill Items</div>
                    <div class="table-responsive">
                        <table class="table table-pro mb-0" id="itemsTable">
                            <thead>
                                <tr>
                                    <th>Medicine</th>
                                    <th style="width:100px">Rate</th>
                                    <th style="width:80px">Qty</th>
                                    <th style="width:90px">Disc %</th>
                                    <th style="width:100px">Disc Amt</th>
                                    <th style="width:100px">Amount</th>
                                    <th style="width:50px"></th>
                                </tr>
                            </thead>
                            <tbody id="itemsBody">
                                <tr id="emptyRow">
                                    <td colspan="6" class="billing-empty-msg">Search and add medicines above</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="panel-card billing-sidebar">
                    <div class="panel-header">Customer & Payment</div>
                    <div class="panel-body">
                        <div class="mb-3">
                            <label asp-for="Input.CustomerName" class="form-label"></label>
                            <input asp-for="Input.CustomerName" class="form-control" id="customerName" />
                            <span asp-validation-for="Input.CustomerName" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.CustomerPhone" class="form-label"></label>
                            <input asp-for="Input.CustomerPhone" class="form-control" id="customerPhone" />
                            <span asp-validation-for="Input.CustomerPhone" class="text-danger"></span>
                            <small class="text-muted" id="customerPhoneHint">Required when payment is Due</small>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.PaymentMethod" class="form-label"></label>
                            <select asp-for="Input.PaymentMethod" class="form-select" id="paymentMethod">
                                <option value="Cash">Cash</option>
                                <option value="Online">Online / Card</option>
                                <option value="Due">Due</option>
                            </select>
                        </div>

                        <hr class="billing-divider" />
                        <div class="billing-total-row"><span>Subtotal</span><span id="subtotalDisplay">0.00</span></div>
                        <div class="billing-total-row"><span>Discount (after Subtotal)</span><span id="discountDisplay">0.00</span></div>

                        <div class="billing-total-row billing-total-final"><span>Total</span><span id="totalDisplay">0.00</span></div>

                        <input type="hidden" asp-for="Input.ItemsJson" id="itemsJson" />
                        <button type="submit" class="btn btn-accent btn-lg w-100 mt-3" id="generateBtn">Save Changes</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
    }

</div>

<script id="initialBillData" type="application/json">@Html.Raw(Model.InitialItemsJson)</script>

@section Styles {
    <link rel="stylesheet" href="~/css/billing.css" asp-append-version="true" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/billing.js" asp-append-version="true"></script>
}
