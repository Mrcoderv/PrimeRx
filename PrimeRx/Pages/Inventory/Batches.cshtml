@page
@model PrimeRx.Pages.Inventory.BatchesModel
@{
    ViewData["Title"] = "Batch-wise Stock";
}

<div class="page-header mb-3">
    <div>
        <h1 class="page-title">Batch-wise Stock</h1>
        <p class="page-subtitle">Multi-batch inventory view with expiry status per lot</p>
    </div>
    <a asp-page="/Purchase/Return/Create" class="btn btn-outline-secondary"><i class="bi bi-arrow-return-left me-1"></i>Return to Supplier</a>
</div>

<div class="panel-card mb-3">
    <div class="panel-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-6">
                <label class="form-label small">Search Medicine / Batch #</label>
                <input type="text" name="search" value="@Model.SearchTerm" class="form-control" placeholder="Type medicine name or batch number…" />
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary flex-grow-1">Search</button>
                <a asp-page="/Inventory/Batches" class="btn btn-outline-secondary">Clear</a>
            </div>
        </form>
    </div>
</div>

<div class="panel-card">
    <div class="panel-header d-flex justify-content-between align-items-center">
        <span>@Model.Batches.Count batch(es) in stock</span>
    </div>
    <div class="table-responsive">
        <table class="table table-pro mb-0">
            <thead>
                <tr>
                    <th>Medicine</th>
                    <th>Batch #</th>
                    <th class="text-center">Qty in Batch</th>
                    <th class="text-end">Purchase Price</th>
                    <th>Source</th>
                    <th>Expiry</th>
                    <th>Received</th>
                    <th style="width:90px"></th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Batches.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">No batches found</td></tr>
                }
                @foreach (var b in Model.Batches.OrderBy(x => x.ExpiryDate ?? DateTime.MaxValue))
                {
                    var daysLeft = b.ExpiryDate.HasValue ? (b.ExpiryDate.Value - DateTime.Today).Days : (int?)null;
                    var rowClass = daysLeft.HasValue
                        ? (daysLeft < 0 ? "table-danger" : daysLeft < 30 ? "table-danger" : daysLeft < 90 ? "table-warning" : "")
                        : "";
                    <tr class="@rowClass">
                        <td class="fw-semibold">@b.Medicine.Name</td>
                        <td>@b.BatchNumber</td>
                        <td class="text-center">@b.Quantity</td>
                        <td class="text-end">@(b.PurchasePrice.ToRs())</td>
                        <td>@(string.IsNullOrWhiteSpace(b.PurchaseSource) ? "—" : b.PurchaseSource)</td>
                        <td>
                            @if (b.ExpiryDate.HasValue)
                            {
                                <span>
                                    @b.ExpiryDate.Value.ToString("MMM yyyy")
                                    @if (daysLeft < 0)
                                    {
                                        <span class="badge bg-danger ms-1">Expired</span>
                                    }
                                    else if (daysLeft < 30)
                                    {
                                        <span class="badge bg-danger ms-1">@daysLeft days left</span>
                                    }
                                    else if (daysLeft < 90)
                                    {
                                        <span class="badge bg-warning text-dark ms-1">@daysLeft days left</span>
                                    }
                                </span>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td><small class="text-muted">@b.CreatedAt.ToString("dd MMM yyyy")</small></td>
                        <td>
                            <a asp-page="/Purchase/Return/Create" class="btn btn-sm btn-outline-danger" title="Return this batch">
                                <i class="bi bi-arrow-return-left"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
