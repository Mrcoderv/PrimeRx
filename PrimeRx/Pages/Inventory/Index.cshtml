@page
@model PrimeRx.Pages.Inventory.IndexModel
@{
    ViewData["Title"] = "Inventory";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Inventory Management</h1>
        <p class="page-subtitle">Track stock levels, purchases, and medicine catalog</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-page="/Inventory/AddMedicine" class="btn btn-accent"><i class="bi bi-plus-lg me-1"></i>Add Medicine</a>
        <a asp-page="/Inventory/Adjust" class="btn btn-outline-accent">Stock Adjustment</a>
        <a asp-page="/Inventory/History" class="btn btn-outline-accent">History</a>
        <a asp-page-handler="ExportStock" class="btn btn-outline-accent"><i class="bi bi-download me-1"></i>Export Stock</a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

@if (Model.LowStock.Any())
{
    <div class="alert alert-warning">
        <strong><i class="bi bi-exclamation-triangle me-1"></i>Low Stock:</strong>
        @string.Join(", ", Model.LowStock.Select(m => $"{m.Name} ({m.StockQuantity})"))
    </div>
}

@if (Model.ExpiringSoon.Any())
{
    <div class="alert alert-danger">
        <strong><i class="bi bi-calendar-x me-1"></i>Expiry Alert:</strong>
        @string.Join(", ", Model.ExpiringSoon.Select(m => $"{m.Name} ({m.ExpiryDate:dd-MM-yyyy})"))
    </div>
}

<form method="get" class="mb-3">
    <div class="row">
        <div class="col-lg-6">
            <div class="input-group">
                <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search medicines..." />
                <button class="btn btn-accent" type="submit"><i class="bi bi-search"></i></button>
            </div>
        </div>
    </div>
</form>

@section Styles {
    <style>
        .toggle-batches-btn {
            font-size: 1rem;
            transition: transform 0.2s ease;
            box-shadow: none !important;
            padding: 0.25rem 0.5rem;
        }
        .toggle-batches-btn:hover {
            transform: scale(1.15);
        }
        .batch-detail-row {
            background-color: var(--rx-table-head-bg) !important;
        }
        .batch-detail-card {
            border: 1px solid var(--rx-border) !important;
            border-radius: 12px !important;
            background: var(--rx-dropdown-bg) !important;
            box-shadow: inset 0 2px 8px rgba(0, 0, 0, 0.15);
        }
        .batch-table {
            background: transparent !important;
            --bs-table-bg: transparent !important;
        }
        .batch-table th {
            font-size: 0.72rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--rx-text-muted) !important;
            border-bottom: 2px solid var(--rx-border) !important;
            background: transparent !important;
        }
        .batch-table td {
            font-size: 0.85rem;
            border-bottom: 1px solid var(--rx-table-border) !important;
            background: transparent !important;
        }
        /* Highlight row if expired or near expiry */
        .batch-row-expired {
            background-color: rgba(239, 68, 68, 0.08) !important;
        }
        .batch-row-warning {
            background-color: rgba(245, 158, 11, 0.05) !important;
        }
    </style>
}

<div class="panel-card">
    <div class="table-responsive">
        <table class="table table-pro mb-0">
            <thead>
                <tr>
                    <th style="width: 45px;"></th>
                    <th>Medicine</th>
                    <th>Generic</th>
                    <th>Category</th>
                    <th>Stock</th>
                    <th>MRP</th>
                    <th>Purchase</th>
                    <th>Expiry</th>
                    <th>Status</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th></th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Medicines)
                {
                    var lowStock = m.StockQuantity <= m.LowStockThreshold;
                    <tr>
                        <td class="text-center">
                            <button class="btn btn-sm btn-link text-decoration-none toggle-batches-btn" data-medicine-id="@m.Id" type="button" title="View batches">
                                <i class="bi bi-chevron-right text-primary"></i>
                            </button>
                        </td>
                        <td><strong>@m.Name</strong></td>
                        <td>@m.GenericName</td>
                        <td>@m.Category</td>
                        <td>@m.StockQuantity</td>
                        <td>@(m.MRP.ToRs())</td>
                        <td>@(m.PurchasePrice.ToRs())</td>
                        <td>@(m.ExpiryDate?.ToString("dd-MM-yyyy") ?? "-")</td>
                        <td>
                            <span class="badge-status @(lowStock ? "partial" : "paid")">
                                @(lowStock ? "Low Stock" : "In Stock")
                            </span>
                        </td>
                        @if (User.IsInRole("Admin"))
                        {
                            <td>
                                <a asp-page="/Admin/Medicines/Edit" asp-route-id="@m.Id" class="btn btn-sm btn-outline-accent">Edit</a>
                            </td>
                        }
                    </tr>
                    <tr id="batches-@m.Id" class="d-none batch-detail-row">
                        <td colspan="@(User.IsInRole("Admin") ? 10 : 9)" class="px-4 py-3">
                            <div class="card batch-detail-card p-3">
                                <h6 class="fw-bold mb-3 d-flex align-items-center gap-2">
                                    <i class="bi bi-layers text-primary"></i>
                                    Batches for @m.Name
                                </h6>
                                @if (Model.MedicineBatches.TryGetValue(m.Id, out var batches) && batches.Any())
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm batch-table mb-0">
                                            <thead>
                                                <tr>
                                                    <th>Batch Number</th>
                                                    <th class="text-center">Qty in Batch</th>
                                                    <th class="text-end">Purchase Price</th>
                                                    <th>Expiry</th>
                                                    <th>Received</th>
                                                    <th>Source</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var b in batches.OrderBy(x => x.ExpiryDate ?? DateTime.MaxValue))
                                                {
                                                    var daysLeft = b.ExpiryDate.HasValue ? (b.ExpiryDate.Value - DateTime.Today).Days : (int?)null;
                                                    var isExpired = daysLeft.HasValue && daysLeft.Value < 0;
                                                    var isSoonExpiring = daysLeft.HasValue && daysLeft.Value >= 0 && daysLeft.Value < 90;
                                                    
                                                    var rowClass = isExpired ? "batch-row-expired" : (isSoonExpiring ? "batch-row-warning" : "");
                                                    var badgeClass = isExpired ? "bg-danger text-white" : (isSoonExpiring ? "bg-warning text-dark" : "bg-success text-white");
                                                    
                                                    <tr class="@rowClass">
                                                        <td class="fw-semibold">@b.BatchNumber</td>
                                                        <td class="text-center fw-bold">@b.Quantity</td>
                                                        <td class="text-end">@(b.PurchasePrice.ToRs())</td>
                                                        <td>
                                                            @if (b.ExpiryDate.HasValue)
                                                            {
                                                                <span class="badge @badgeClass">
                                                                    @b.ExpiryDate.Value.ToString("dd-MM-yyyy")
                                                                    @(isExpired ? " (Expired)" : isSoonExpiring ? " (Soon)" : "")
                                                                </span>
                                                            }
                                                            else
                                                            {
                                                                <span class="text-muted">—</span>
                                                            }
                                                        </td>
                                                        <td><small class="text-muted">@b.CreatedAt.ToString("dd-MM-yyyy")</small></td>
                                                        <td>@(string.IsNullOrWhiteSpace(b.PurchaseSource) ? "—" : b.PurchaseSource)</td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted py-2 small">
                                        <i class="bi bi-info-circle me-1"></i>No batches found for this medicine.
                                    </div>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.toggle-batches-btn').click(function () {
                var medicineId = $(this).data('medicine-id');
                var targetRow = $('#batches-' + medicineId);
                var icon = $(this).find('i');
                
                targetRow.toggleClass('d-none');
                if (targetRow.hasClass('d-none')) {
                    icon.removeClass('bi-chevron-down').addClass('bi-chevron-right');
                } else {
                    icon.removeClass('bi-chevron-right').addClass('bi-chevron-down');
                }
            });
        });
    </script>
}
