@page
@model PrimeRx.Pages.Inventory.IndexModel
@{
    ViewData["Title"] = "Inventory";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Inventory Management</h1>
        <p class="page-subtitle">Track stock levels, purchases, and medicine catalog</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-page="/Inventory/AddMedicine" class="btn btn-accent"><i class="bi bi-plus-lg me-1"></i>Add Medicine</a>
        <a asp-page="/Inventory/Purchase" class="btn btn-outline-accent">Purchase Entry</a>
        <a asp-page="/Inventory/Adjust" class="btn btn-outline-accent">Stock Adjustment</a>
        <a asp-page="/Inventory/History" class="btn btn-outline-accent">History</a>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}

@if (Model.LowStock.Any())
{
    <div class="alert alert-warning">
        <strong><i class="bi bi-exclamation-triangle me-1"></i>Low Stock:</strong>
        @string.Join(", ", Model.LowStock.Select(m => $"{m.Name} ({m.StockQuantity})"))
    </div>
}

@if (Model.ExpiringSoon.Any())
{
    <div class="alert alert-danger">
        <strong><i class="bi bi-calendar-x me-1"></i>Expiry Alert:</strong>
        @string.Join(", ", Model.ExpiringSoon.Select(m => $"{m.Name} ({m.ExpiryDate:dd-MM-yyyy})"))
    </div>
}

<form method="get" class="mb-3">
    <div class="input-group col-lg-6">
        <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search medicines..." />
        <button class="btn btn-accent" type="submit"><i class="bi bi-search"></i></button>
    </div>
</form>

<div class="panel-card">
    <div class="table-responsive">
        <table class="table table-pro mb-0">
            <thead>
                <tr>
                    <th>Medicine</th>
                    <th>Generic</th>
                    <th>Category</th>
                    <th>Stock</th>
                    <th>MRP</th>
                    <th>Purchase</th>
                    <th>Expiry</th>
                    <th>Status</th>
                    @if (User.IsInRole("Admin"))
                    {
                        <th></th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var m in Model.Medicines)
                {
                    var lowStock = m.StockQuantity <= m.LowStockThreshold;
                    <tr>
                        <td><strong>@m.Name</strong></td>
                        <td>@m.GenericName</td>
                        <td>@m.Category</td>
                        <td>@m.StockQuantity</td>
                        <td>Rs. @m.MRP.ToString("N2")</td>
                        <td>Rs. @m.PurchasePrice.ToString("N2")</td>
                        <td>@(m.ExpiryDate?.ToString("dd-MM-yyyy") ?? "-")</td>
                        <td>
                            <span class="badge-status @(lowStock ? "partial" : "paid")">
                                @(lowStock ? "Low Stock" : "In Stock")
                            </span>
                        </td>
                        @if (User.IsInRole("Admin"))
                        {
                            <td>
                                <a asp-page="/Admin/Medicines/Edit" asp-route-id="@m.Id" class="btn btn-sm btn-outline-accent">Edit</a>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
