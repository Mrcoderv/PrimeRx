@page
@model PrimeRx.Pages.Inventory.PurchaseModel
@{
    ViewData["Title"] = "Purchase Entry";
}

<h2 class="mb-3">Purchase Entry</h2>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="card shadow-sm col-lg-8">
    <div class="card-body">
        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.MedicineId" class="form-label">Medicine</label>
                <select asp-for="Input.MedicineId" class="form-select" asp-items="Model.MedicineOptions"></select>
            </div>
            <div class="row g-3">
                <div class="col-md-4">
                    <label asp-for="Input.Quantity" class="form-label">Quantity</label>
                    <input asp-for="Input.Quantity" class="form-control" type="number" min="1" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Input.PurchasePrice" class="form-label">Purchase Price (per unit)</label>
                    <input asp-for="Input.PurchasePrice" class="form-control" type="number" step="0.01" min="0" placeholder="Leave blank to keep current" />
                </div>
                <div class="col-md-4">
                    <label asp-for="Input.ExpiryDate" class="form-label">Expiry Date</label>
                    <input asp-for="Input.ExpiryDate" class="form-control" type="date" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.BatchNumber" class="form-label">Batch Number</label>
                    <input asp-for="Input.BatchNumber" class="form-control" placeholder="e.g. BATCH-20260622" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.PurchaseSource" class="form-label">Purchase Source / Supplier</label>
                    <input asp-for="Input.PurchaseSource" class="form-control" placeholder="e.g. ABC Distributors" />
                </div>
            </div>
            <p class="text-muted small mt-2 mb-3">Entering a purchase price recalculates MRP using the default margin set in Settings.</p>
            <button type="submit" class="btn btn-success">Add Stock</button>
            <a asp-page="/Inventory/Index" class="btn btn-outline-secondary">Back</a>
        </form>
    </div>
</div>
