@page
@model PrimeRx.Pages.Due.IndexModel
@{
    ViewData["Title"] = "Due Payments";
}

<h2 class="mb-3">Due Payment Management</h2>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@Model.Search" class="form-control" placeholder="Search customer, phone, bill..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">Search</button>
    </div>
</form>

<div class="table-responsive card shadow-sm">
    <table class="table table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Bill #</th>
                <th>Date</th>
                <th>Customer</th>
                <th>Phone</th>
                <th>Total</th>
                <th>Paid</th>
                <th>Due</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var bill in Model.DueBills)
            {
                <tr>
                    <td>@bill.BillNumber</td>
                    <td>@bill.BillDate.ToString("dd-MM-yyyy")</td>
                    <td>@bill.CustomerName</td>
                    <td>@bill.CustomerPhone</td>
                    <td>@bill.FinalAmount.ToString("N2")</td>
                    <td>@bill.PaidAmount.ToString("N2")</td>
                    <td class="text-danger fw-semibold">@bill.DueAmount.ToString("N2")</td>
                    <td><span class="badge bg-warning text-dark">@bill.PaymentStatus</span></td>
                    <td>
                        <a asp-page="/Due/Pay" asp-route-id="@bill.Id" class="btn btn-sm btn-primary">Collect</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.DueBills.Any())
{
    <p class="text-muted text-center mt-4">No outstanding due payments.</p>
}
