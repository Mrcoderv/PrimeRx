@page
@model PrimeRx.Pages.Due.IndexModel
@{
    ViewData["Title"] = "Due Payments";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Due Payment Management</h1>
        <p class="page-subtitle">Track and collect outstanding customer payments</p>
    </div>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <label for="dueSearch" class="form-label small mb-1">Search</label>
        <input type="text" id="dueSearch" name="search" value="@Model.Search" class="form-control" placeholder="Search customer, phone, bill..." />
    </div>
    <div class="col-auto d-flex align-items-end">
        <button type="submit" class="btn btn-accent"><i class="bi bi-search me-1"></i>Search</button>
    </div>
</form>

<div class="panel-card">
    <div class="p-0 panel-body-flush">
        <div class="table-responsive">
            <table class="table table-pro mb-0">
                <thead>
                    <tr>
                        <th>Bill #</th>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Phone</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Paid</th>
                        <th class="text-end">Due</th>
                        <th>Status</th>
                        <th style="width:100px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var bill in Model.DueBills)
                    {
                        <tr>
                            <td><strong>@bill.BillNumber</strong></td>
                            <td>@bill.BillDate.ToString("dd-MM-yyyy")</td>
                            <td>@bill.CustomerName</td>
                            <td>@bill.CustomerPhone</td>
                            <td class="text-end">Rs. @bill.FinalAmount.ToString("N2")</td>
                            <td class="text-end positive">Rs. @bill.PaidAmount.ToString("N2")</td>
                            <td class="text-end negative fw-semibold">Rs. @bill.DueAmount.ToString("N2")</td>
                            <td><span class="badge-status @(bill.PaymentStatus == "Due" ? "due" : "partial")">@bill.PaymentStatus</span></td>
                            <td>
                                <a asp-page="/Due/Pay" asp-route-id="@bill.Id" class="btn btn-accent btn-sm w-100">Collect</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!Model.DueBills.Any())
{
    <div class="text-center text-muted mt-4 py-5">
        <i class="bi bi-check-circle display-6 d-block mb-2" style="opacity:0.4"></i>
        No outstanding due payments.
    </div>
}
