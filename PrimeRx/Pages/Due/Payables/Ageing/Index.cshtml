@page
@model PrimeRx.Pages.Due.Payables.Ageing.IndexModel
@{
    ViewData["Title"] = "Ageing Dues — Payables";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Ageing Dues</h1>
        <p class="page-subtitle">Detailed payable ageing report — supplier-wise outstanding with age breakdown</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-page-handler="Pdf"
           asp-route-supplier="@Model.SupplierFilter"
           asp-route-from="@Model.FromDate?.ToString("yyyy-MM-dd")"
           asp-route-to="@Model.ToDate?.ToString("yyyy-MM-dd")"
           class="btn btn-outline-accent">
            <i class="bi bi-file-earmark-pdf me-1"></i>PDF
        </a>
        <a asp-page-handler="Excel"
           asp-route-supplier="@Model.SupplierFilter"
           asp-route-from="@Model.FromDate?.ToString("yyyy-MM-dd")"
           asp-route-to="@Model.ToDate?.ToString("yyyy-MM-dd")"
           class="btn btn-outline-accent">
            <i class="bi bi-file-earmark-excel me-1"></i>Excel
        </a>
    </div>
</div>

<!-- Company header -->
<div class="ageing-report-header mb-3">
    <h3 class="mb-1">@Model.Report.CompanyName</h3>
    @if (!string.IsNullOrWhiteSpace(Model.Report.CompanyAddress))
    {
        <p class="mb-0 text-muted">@Model.Report.CompanyAddress</p>
    }
    <h5 class="mt-2 mb-0"><strong>@Model.Report.Title</strong></h5>
    <small class="text-muted">Generated: @Model.Report.GeneratedAt.ToString("dd MMM yyyy HH:mm")</small>
</div>

<!-- Filters -->
<div class="panel-card mb-4">
    <div class="panel-body">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-end">
            <div>
                <label class="form-label small mb-1" for="supplier">Supplier</label>
                <input type="text" name="supplier" id="supplier" value="@Model.SupplierFilter"
                       placeholder="Filter supplier..." class="form-control form-control-sm" style="min-width:160px" />
            </div>
            <div>
                <label class="form-label small mb-1" for="from">From</label>
                <input type="date" name="from" id="from" value="@Model.FromDate?.ToString("yyyy-MM-dd")"
                       class="form-control form-control-sm" />
            </div>
            <div>
                <label class="form-label small mb-1" for="to">To</label>
                <input type="date" name="to" id="to" value="@Model.ToDate?.ToString("yyyy-MM-dd")"
                       class="form-control form-control-sm" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-accent btn-sm">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
                <a asp-page="/Due/Payables/Ageing/Index" class="btn btn-outline-secondary btn-sm">Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- Summary cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-primary">
            <div class="stat-label">Total Entries</div>
            <div class="stat-value">@Model.Report.TotalCount</div>
            <div class="stat-foot">Payable records</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-danger">
            <div class="stat-label">Grand Total (Pending)</div>
            <div class="stat-value">Rs. @Model.Report.GrandTotal.ToString("N2")</div>
            <div class="stat-foot">Total outstanding</div>
        </div>
    </div>
</div>

<!-- Ageing dues table -->
<div class="panel-card">
    <div class="panel-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="bi bi-clock-history me-2"></i>Ageing Dues Details
        </h5>
        <span class="badge bg-secondary">@Model.Report.TotalCount record(s)</span>
    </div>
    <div class="p-0 panel-body-flush">
        <div class="table-responsive">
            <table class="table table-pro mb-0 ageing-dues-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Inv. No</th>
                        <th>Narration</th>
                        <th class="text-end">Amount</th>
                        <th class="text-end">Age (Days)</th>
                        <th class="text-end">Balance</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Report.Rows.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="bi bi-inbox display-6 d-block mb-2 opacity-40"></i>
                                No payable records found for the selected criteria.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var r in Model.Report.Rows)
                        {
                            var ageClass = r.AgeDays > 90 ? "age-90-plus"
                                : r.AgeDays > 60 ? "age-61-90"
                                : r.AgeDays > 30 ? "age-31-60"
                                : "";
                            <tr class="@ageClass">
                                <td>@r.DueDate.ToString("dd-MM-yyyy")</td>
                                <td class="text-muted small">@(r.InvoiceNo ?? "—")</td>
                                <td>
                                    <strong>@r.SupplierName</strong>
                                    @if (!string.IsNullOrWhiteSpace(r.Description))
                                    {
                                        <div class="small text-muted">@r.Description</div>
                                    }
                                </td>
                                <td class="text-end">@r.Amount.ToString("N2")</td>
                                <td class="text-end">
                                    @if (r.AgeDays > 90)
                                    {
                                        <span class="text-danger fw-bold">@r.AgeDays</span>
                                    }
                                    else if (r.AgeDays > 60)
                                    {
                                        <span class="text-warning fw-semibold">@r.AgeDays</span>
                                    }
                                    else
                                    {
                                        <span>@r.AgeDays</span>
                                    }
                                </td>
                                <td class="text-end fw-bold" style="color:var(--danger)">@r.PendingAmount.ToString("N2")</td>
                            </tr>
                        }
                    }
                </tbody>
                @if (Model.Report.Rows.Any())
                {
                    <tfoot>
                        <tr class="report-total-row">
                            <td colspan="3"></td>
                            <td class="text-end fw-bold">Grand Total</td>
                            <td></td>
                            <td class="text-end fw-bold" style="color:var(--danger); font-size:1.05rem;">
                                Rs. @Model.Report.GrandTotal.ToString("N2")
                            </td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>
</div>

@section Styles {
<style>
    .ageing-report-header {
        background: var(--rx-panel);
        border: 1px solid var(--rx-border);
        border-radius: var(--rx-radius);
        padding: 1rem 1.25rem;
    }
    [data-bs-theme="light"] .ageing-report-header {
        background: #ffffff;
    }
    .ageing-report-header h3 {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--rx-heading);
    }
    .ageing-report-header h5 {
        font-size: 1rem;
        color: var(--rx-cyan);
    }
    .ageing-report-header small {
        font-size: 0.75rem;
    }
    .ageing-dues-table tbody td {
        vertical-align: middle;
    }
    .ageing-dues-table tbody tr.age-31-60 {
        background: rgba(245,158,11,0.06);
    }
    .ageing-dues-table tbody tr.age-61-90 {
        background: rgba(239,68,68,0.06);
    }
    .ageing-dues-table tbody tr.age-90-plus {
        background: rgba(220,38,38,0.1);
    }
</style>
}
