@page
@model PrimeRx.Pages.Reports.IndexModel
@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Reports & Analytics</h1>
        <p class="page-subtitle">Sales performance, charts, and exportable business reports</p>
    </div>
</div>

<!-- Summary strip -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-primary">
            <div class="stat-label">Today Sales</div>
            <div class="stat-value">@(Model.Stats.TodaySales.ToRs())</div>
            <div class="stat-foot">@Model.Stats.TodayBills bills</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-info">
            <div class="stat-label">Month Sales</div>
            <div class="stat-value">@(Model.Stats.MonthSales.ToRs())</div>
            <div class="stat-foot">This month</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-warning">
            <div class="stat-label">Outstanding Due</div>
            <div class="stat-value">@(Model.Stats.OutstandingDue.ToRs())</div>
            <div class="stat-foot">Pending collection</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-success">
            <div class="stat-label">Chart Period</div>
            <div class="stat-value" style="font-size:1.25rem">30 Days</div>
            <div class="stat-foot">Sales &amp; medicine trends</div>
        </div>
    </div>
</div>

<!-- Charts -->
<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="panel-card h-100">
            <div class="panel-header d-flex justify-content-between align-items-center">
                <h5><i class="bi bi-bar-chart-line me-2"></i>Daily Sales Trend</h5>
                <span class="report-chip">30 days</span>
            </div>
            <div class="panel-body chart-panel">
                <canvas id="monthlySalesChart" height="110"></canvas>
                <div id="salesChartEmpty" class="chart-empty d-none">No sales data for the selected period.</div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="panel-card h-100">
            <div class="panel-header"><h5><i class="bi bi-pie-chart me-2"></i>Top Medicines</h5></div>
            <div class="panel-body chart-panel">
                <canvas id="medicinePieChart" height="200"></canvas>
                <div id="medChartEmpty" class="chart-empty d-none">No medicine sales data yet.</div>
            </div>
        </div>
    </div>
</div>

<!-- Report generators -->
<div class="panel-card mb-4">
    <div class="panel-header">
        <h5><i class="bi bi-file-earmark-bar-graph me-2 text-info"></i>Generate Reports</h5>
        <p class="report-section-hint mb-0">Pick a report, set dates if needed, then view on screen or export.</p>
    </div>
    <div class="panel-body">
        <div class="report-section-label">Sales Reports</div>
        <div class="row g-3 mb-4">
            <div class="col-md-6 col-xl-4">
                <div class="report-action-card">
                    <div class="report-action-title"><i class="bi bi-calendar-day me-2"></i>Daily Sales</div>
                    <form method="get" asp-page-handler="DailySales">
                        <input type="date" name="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control form-control-sm mb-2" />
                        <div class="btn-group-sm d-flex gap-2">
                            <button type="submit" name="format" value="view" class="btn btn-accent btn-sm flex-fill">View</button>
                            <button type="submit" name="format" value="pdf" class="btn btn-outline-accent btn-sm">PDF</button>
                            <button type="submit" name="format" value="excel" class="btn btn-outline-accent btn-sm">Excel</button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="report-action-card">
                    <div class="report-action-title"><i class="bi bi-calendar-month me-2"></i>Monthly Sales</div>
                    <form method="get" asp-page-handler="MonthlySales">
                        <div class="row g-2 mb-2">
                            <div class="col-6"><input type="number" name="year" value="@DateTime.Today.Year" class="form-control form-control-sm" /></div>
                            <div class="col-6"><input type="number" name="month" value="@DateTime.Today.Month" class="form-control form-control-sm" min="1" max="12" /></div>
                        </div>
                        <div class="btn-group-sm d-flex gap-2">
                            <button type="submit" name="format" value="view" class="btn btn-accent btn-sm flex-fill">View</button>
                            <button type="submit" name="format" value="pdf" class="btn btn-outline-accent btn-sm">PDF</button>
                            <button type="submit" name="format" value="excel" class="btn btn-outline-accent btn-sm">Excel</button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="report-action-card">
                    <div class="report-action-title"><i class="bi bi-capsule me-2"></i>Medicine Sales</div>
                    <p class="text-muted-small mb-2">Last 30 days breakdown</p>
                    <form method="get" asp-page-handler="MedicineSales" class="d-flex gap-2">
                        <button type="submit" name="format" value="view" class="btn btn-accent btn-sm flex-fill">View</button>
                        <button type="submit" name="format" value="excel" class="btn btn-outline-accent btn-sm">Excel</button>
                    </form>
                </div>
            </div>
        </div>

        <div class="report-section-label">Business &amp; Inventory</div>
        <div class="row g-3">
            <div class="col-md-6 col-xl-4">
                <div class="report-action-card">
                    <div class="report-action-title"><i class="bi bi-currency-rupee me-2"></i>Profit &amp; Loss</div>
                    <form method="get" asp-page-handler="ProfitLoss">
                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <label class="form-label small mb-1">From</label>
                                <input type="date" name="from" value="@DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-1">To</label>
                                <input type="date" name="to" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" name="format" value="view" class="btn btn-accent btn-sm flex-fill">View</button>
                            <button type="submit" name="format" value="pdf" class="btn btn-outline-accent btn-sm">PDF</button>
                            <button type="submit" name="format" value="excel" class="btn btn-outline-accent btn-sm">Excel</button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="report-action-card">
                    <div class="report-action-title"><i class="bi bi-wallet2 me-2"></i>Due Collection</div>
                    <form method="get" asp-page-handler="DueCollection">
                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <label class="form-label small mb-1">From</label>
                                <input type="date" name="from" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-1">To</label>
                                <input type="date" name="to" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" name="format" value="view" class="btn btn-accent btn-sm flex-fill">View</button>
                            <button type="submit" name="format" value="pdf" class="btn btn-outline-accent btn-sm">PDF</button>
                            <button type="submit" name="format" value="excel" class="btn btn-outline-accent btn-sm">Excel</button>
                        </div>
                    </form>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="report-action-card">
                    <div class="report-action-title"><i class="bi bi-box-seam me-2"></i>Inventory</div>
                    <p class="text-muted-small mb-2">Current stock snapshot</p>
                    <div class="d-flex gap-2">
                        <a asp-page-handler="Inventory" class="btn btn-accent btn-sm flex-fill">View</a>
                        <a asp-page-handler="Inventory" asp-route-format="pdf" class="btn btn-outline-accent btn-sm">PDF</a>
                        <a asp-page-handler="Inventory" asp-route-format="excel" class="btn btn-outline-accent btn-sm">Excel</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="report-action-card">
                    <div class="report-action-title"><i class="bi bi-exclamation-triangle me-2"></i>Expiry Alert</div>
                    <p class="text-muted-small mb-2">Medicines expiring in 90 days</p>
                    <div class="d-flex gap-2">
                        <a asp-page-handler="Expiry" class="btn btn-accent btn-sm flex-fill">View</a>
                        <a asp-page-handler="Expiry" asp-route-format="pdf" class="btn btn-outline-accent btn-sm">PDF</a>
                        <a asp-page-handler="Expiry" asp-route-format="excel" class="btn btn-outline-accent btn-sm">Excel</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="report-section-label mt-4">Purchase Reports</div>
        <div class="row g-3">
            <div class="col-md-8 col-xl-6">
                <div class="report-action-card">
                    <div class="report-action-title"><i class="bi bi-truck me-2"></i>Purchase Report</div>
                    <form method="get" asp-page-handler="PurchaseReport">
                        <div class="row g-2 mb-2">
                            <div class="col-6">
                                <label class="form-label small mb-1">From</label>
                                <input type="date" name="from" value="@DateTime.Today.AddMonths(-1).ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small mb-1">To</label>
                                <input type="date" name="to" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                            </div>
                        </div>
                        <div class="mb-2">
                            <input type="text" name="supplier" placeholder="Filter by supplier (optional)" class="form-control form-control-sm" />
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" name="format" value="view" class="btn btn-accent btn-sm flex-fill">View</button>
                            <button type="submit" name="format" value="pdf" class="btn btn-outline-accent btn-sm">PDF</button>
                            <button type="submit" name="format" value="excel" class="btn btn-outline-accent btn-sm">Excel</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="report-section-label mt-4">Supplier & Audit Reports</div>
        <div class="row g-3">
            <div class="col-md-6 col-xl-4">
                <div class="report-action-card">
                    <div class="report-action-title"><i class="bi bi-graph-up-arrow me-2"></i>Supplier Profit Analysis</div>
                    <p class="text-muted-small mb-2">Purchase cost vs MRP value per supplier — margin breakdown</p>
                    <div class="d-flex gap-2">
                        <a asp-page-handler="SupplierProfit" class="btn btn-accent btn-sm flex-fill">View</a>
                        <a asp-page-handler="SupplierProfit" asp-route-format="excel" class="btn btn-outline-accent btn-sm">Excel</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="report-action-card">
                    <div class="report-action-title"><i class="bi bi-calendar3 me-2"></i>Monthly Purchase by Supplier</div>
                    <form method="get" asp-page-handler="MonthlySupplier">
                        <div class="mb-2">
                            <input type="number" name="year" value="@DateTime.Today.Year" class="form-control form-control-sm" placeholder="Year" min="2020" max="2099" />
                        </div>
                        <button type="submit" class="btn btn-accent btn-sm w-100">View</button>
                    </form>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="report-action-card">
                    <div class="report-action-title"><i class="bi bi-credit-card me-2"></i>Payables to Suppliers</div>
                    <p class="text-muted-small mb-2">Outstanding amounts owed to each supplier</p>
                    <div class="d-flex gap-2">
                        <a asp-page-handler="SupplierPayables" class="btn btn-accent btn-sm flex-fill">View</a>
                        <a asp-page-handler="SupplierPayables" asp-route-format="excel" class="btn btn-outline-accent btn-sm">Excel</a>
                    </div>
                </div>
            </div>
            <div class="col-md-6 col-xl-4">
                <div class="report-action-card">
                    <div class="report-action-title"><i class="bi bi-journal-text me-2"></i>Audit Log</div>
                    <p class="text-muted-small mb-2">System-wide activity trail — select period</p>
                    <div class="d-flex gap-1 flex-wrap mb-2">
                        <a asp-page-handler="AuditReport" asp-route-days="30" class="btn btn-sm @(Model.SelectedAuditDays == 30 ? "btn-accent" : "btn-outline-accent")">30 Days</a>
                        <a asp-page-handler="AuditReport" asp-route-days="60" class="btn btn-sm @(Model.SelectedAuditDays == 60 ? "btn-accent" : "btn-outline-accent")">60 Days</a>
                        <a asp-page-handler="AuditReport" asp-route-days="90" class="btn btn-sm @(Model.SelectedAuditDays == 90 ? "btn-accent" : "btn-outline-accent")">90 Days</a>
                        <a asp-page-handler="AuditReport" asp-route-days="180" class="btn btn-sm @(Model.SelectedAuditDays == 180 ? "btn-accent" : "btn-outline-accent")">180 Days</a>
                    </div>
                    <form method="get" asp-page-handler="AuditReport" class="d-flex gap-2 align-items-end">
                        <div class="flex-fill">
                            <label class="form-label small mb-1">From</label>
                            <input type="date" name="from" value="@Model.AuditFrom?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                        </div>
                        <div class="flex-fill">
                            <label class="form-label small mb-1">To</label>
                            <input type="date" name="to" value="@Model.AuditTo?.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
                        </div>
                        <button type="submit" class="btn btn-accent btn-sm">Go</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Report results -->
@if (Model.ReportTitle != null)
{
    <div class="panel-card report-results" id="reportResults">
        <div class="panel-header d-flex justify-content-between align-items-center flex-wrap gap-2">
            <h5 class="mb-0"><i class="bi bi-table me-2"></i>@Model.ReportTitle</h5>
            @if (Model.SummaryText != null)
            {
                <span class="report-summary-badge">@Model.SummaryText</span>
            }
        </div>
        <div class="p-0 panel-body-flush">
            @if (Model.SalesReport != null)
            {
                @if (!Model.SalesReport.Bills.Any())
                {
                    <div class="report-empty">No bills found for this period.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-pro mb-0">
                            <thead><tr><th>Bill #</th><th>Date</th><th>Customer</th><th>Phone</th><th>Amount</th><th>Payment</th><th>Status</th></tr></thead>
                            <tbody>
                                @foreach (var b in Model.SalesReport.Bills)
                                {
                                    <tr>
                                        <td><strong>@b.BillNumber</strong></td>
                                        <td>@b.BillDate.ToString("dd-MM-yyyy HH:mm")</td>
                                        <td>@b.CustomerName</td>
                                        <td>@b.CustomerPhone</td>
                                        <td class="amount-cell">@(b.FinalAmount.ToRs())</td>
                                        <td>@b.PaymentMethod</td>
                                        <td><span class="badge-status @(b.PaymentStatus == "Paid" ? "paid" : b.PaymentStatus == "Due" ? "due" : "partial")">@b.PaymentStatus</span></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="report-total-row">
                                    <td colspan="4" class="text-end"><strong>Total</strong></td>
                                    <td class="amount-cell"><strong>@(Model.SalesReport.TotalSales.ToRs())</strong></td>
                                    <td colspan="2"><strong>@Model.SalesReport.BillCount bills</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
            }
            @if (Model.MedicineSales != null)
            {
                <div class="table-responsive">
                    <table class="table table-pro mb-0">
                        <thead><tr><th>#</th><th>Medicine</th><th>Quantity Sold</th><th>Revenue</th></tr></thead>
                        <tbody>
                            @{ var i = 1; }
                            @foreach (var r in Model.MedicineSales)
                            {
                                <tr>
                                    <td>@i</td>
                                    <td>@r.MedicineName</td>
                                    <td>@r.TotalQuantity</td>
                                    <td class="amount-cell">@(r.TotalAmount.ToRs())</td>
                                </tr>
                                i++;
                            }
                        </tbody>
                    </table>
                </div>
            }
            @if (Model.ProfitLoss != null)
            {
                <div class="panel-body">
                    <div class="row g-3">
                        <div class="col-md-3"><div class="pnl-box"><div class="pnl-label">Revenue</div><div class="pnl-value">@(Model.ProfitLoss.Revenue.ToRs())</div></div></div>
                        <div class="col-md-3"><div class="pnl-box"><div class="pnl-label">Cost of Goods</div><div class="pnl-value">@(Model.ProfitLoss.Cost.ToRs())</div></div></div>
                        <div class="col-md-3"><div class="pnl-box"><div class="pnl-label">Expenses</div><div class="pnl-value">@(Model.ProfitLoss.Expenses.ToRs())</div></div></div>
                        <div class="col-md-3"><div class="pnl-box pnl-profit"><div class="pnl-label">Net Profit</div><div class="pnl-value @(Model.ProfitLoss.Profit >= 0 ? "positive" : "negative")">@(Model.ProfitLoss.Profit.ToRs())</div></div></div>
                        <div class="col-md-3"><div class="pnl-box"><div class="pnl-label">Bills</div><div class="pnl-value">@Model.ProfitLoss.BillCount</div></div></div>
                    </div>
                </div>
            }
            @if (Model.DueReport != null)
            {
                <div class="panel-body">
                    <div class="row g-3">
                        <div class="col-md-6"><div class="pnl-box pnl-profit"><div class="pnl-label">Total Collected</div><div class="pnl-value positive">@(Model.DueReport.TotalCollected.ToRs())</div></div></div>
                        <div class="col-md-6"><div class="pnl-box"><div class="pnl-label">Outstanding Due</div><div class="pnl-value negative">@(Model.DueReport.OutstandingDue.ToRs())</div></div></div>
                    </div>
                </div>
            }
            @if (Model.InventoryMedicines != null)
            {
                <div class="table-responsive">
                    <table class="table table-pro mb-0">
                        <thead><tr><th>Medicine</th><th>Stock</th><th>MRP</th><th>Purchase</th><th>Expiry</th></tr></thead>
                        <tbody>
                            @foreach (var m in Model.InventoryMedicines)
                            {
                                <tr>
                                    <td>@m.Name</td>
                                    <td>@m.StockQuantity</td>
                                    <td class="amount-cell">@(m.MRP.ToRs())</td>
                                    <td class="amount-cell">@(m.PurchasePrice.ToRs())</td>
                                    <td>@(m.ExpiryDate?.ToString("dd-MM-yyyy") ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            @if (Model.ExpiryMedicines != null)
            {
                <div class="table-responsive">
                    <table class="table table-pro mb-0">
                        <thead><tr><th>Medicine</th><th>Stock</th><th>Expiry Date</th><th>Status</th></tr></thead>
                        <tbody>
                            @foreach (var m in Model.ExpiryMedicines)
                            {
                                <tr>
                                    <td>@m.Name</td>
                                    <td>@m.StockQuantity</td>
                                    <td class="negative">@m.ExpiryDate?.ToString("dd-MM-yyyy")</td>
                                    <td><span class="badge-status partial">Expiring</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            @if (Model.PurchaseReport != null)
            {
                <div class="panel-body">
                    <div class="row g-3 mb-4">
                        <div class="col-6 col-md-3">
                            <div class="pnl-box">
                                <div class="pnl-label">Total Spent</div>
                                <div class="pnl-value">@(Model.PurchaseReport.TotalAmount.ToRs())</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="pnl-box">
                                <div class="pnl-label">Purchases</div>
                                <div class="pnl-value">@Model.PurchaseReport.PurchaseCount</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="pnl-box">
                                <div class="pnl-label">Suppliers</div>
                                <div class="pnl-value">@Model.PurchaseReport.SupplierBreakdown.Count</div>
                            </div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="pnl-box">
                                <div class="pnl-label">Medicines Bought</div>
                                <div class="pnl-value">@Model.PurchaseReport.TopMedicines.Count</div>
                            </div>
                        </div>
                    </div>
                </div>

                @if (Model.PurchaseReport.SupplierBreakdown.Any())
                {
                    <div class="px-3 pb-1">
                        <div class="report-section-label">Supplier-wise Spend</div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-pro mb-0">
                            <thead><tr><th>#</th><th>Supplier</th><th class="text-center">Purchases</th><th class="text-end">Total Spend</th></tr></thead>
                            <tbody>
                                @{ var si = 1; }
                                @foreach (var s in Model.PurchaseReport.SupplierBreakdown)
                                {
                                    <tr>
                                        <td>@si</td>
                                        <td class="fw-semibold">@s.SupplierName</td>
                                        <td class="text-center"><span class="badge bg-secondary">@s.PurchaseCount</span></td>
                                        <td class="text-end amount-cell">@(s.TotalSpend.ToRs())</td>
                                    </tr>
                                    si++;
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (Model.PurchaseReport.TopMedicines.Any())
                {
                    <div class="px-3 pt-3 pb-1">
                        <div class="report-section-label">Top Medicines by Spend</div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-pro mb-0">
                            <thead><tr><th>#</th><th>Medicine</th><th class="text-center">Qty Purchased</th><th class="text-end">Total Spend</th></tr></thead>
                            <tbody>
                                @{ var mi = 1; }
                                @foreach (var m in Model.PurchaseReport.TopMedicines)
                                {
                                    <tr>
                                        <td>@mi</td>
                                        <td>@m.MedicineName</td>
                                        <td class="text-center">@m.TotalQuantity</td>
                                        <td class="text-end amount-cell">@(m.TotalSpend.ToRs())</td>
                                    </tr>
                                    mi++;
                                }
                            </tbody>
                        </table>
                    </div>
                }

                @if (Model.PurchaseReport.Purchases.Any())
                {
                    <div class="px-3 pt-3 pb-1">
                        <div class="report-section-label">All Purchases in Period</div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-pro mb-0">
                            <thead><tr><th>Date</th><th>Invoice #</th><th>Supplier</th><th class="text-center">Items</th><th class="text-end">Amount</th><th>Recorded By</th></tr></thead>
                            <tbody>
                                @foreach (var p in Model.PurchaseReport.Purchases)
                                {
                                    <tr>
                                        <td>@p.PurchaseDate.ToString("dd MMM yyyy")</td>
                                        <td>@(p.InvoiceNumber ?? "—")</td>
                                        <td class="fw-semibold">@p.SupplierName</td>
                                        <td class="text-center"><span class="badge bg-secondary">@p.Items.Count</span></td>
                                        <td class="text-end amount-cell">@(p.TotalAmount.ToRs())</td>
                                        <td><small class="text-muted">@(p.CreatedBy ?? "—")</small></td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="report-total-row">
                                    <td colspan="4" class="text-end"><strong>Total</strong></td>
                                    <td class="text-end amount-cell"><strong>@(Model.PurchaseReport.TotalAmount.ToRs())</strong></td>
                                    <td></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
                else
                {
                    <div class="report-empty">No purchases found for this period.</div>
                }
            }

            @if (Model.SupplierProfit != null)
            {
                if (!Model.SupplierProfit.Any())
                {
                    <div class="report-empty">No purchase data found. Add purchases first.</div>
                }
                else
                {
                    <div class="panel-body">
                        <div class="row g-3 mb-4">
                            <div class="col-6 col-md-3">
                                <div class="pnl-box">
                                    <div class="pnl-label">Total Suppliers</div>
                                    <div class="pnl-value">@Model.SupplierProfit.Count</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="pnl-box">
                                    <div class="pnl-label">Total Purchase Cost</div>
                                    <div class="pnl-value">@Model.SupplierProfit.Sum(r => r.TotalCost).ToRs()</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="pnl-box">
                                    <div class="pnl-label">Total MRP Value</div>
                                    <div class="pnl-value">@Model.SupplierProfit.Sum(r => r.TotalMrpValue).ToRs()</div>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="pnl-box pnl-profit">
                                    <div class="pnl-label">Potential Profit</div>
                                    <div class="pnl-value positive">@Model.SupplierProfit.Sum(r => r.PotentialProfit).ToRs()</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-pro mb-0">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Supplier</th>
                                    <th class="text-center">Purchases</th>
                                    <th class="text-center">Units</th>
                                    <th class="text-end">Total Cost</th>
                                    <th class="text-end">MRP Value</th>
                                    <th class="text-end">Potential Profit</th>
                                    <th class="text-end">Margin %</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{ var spi = 1; }
                                @foreach (var r in Model.SupplierProfit)
                                {
                                    <tr>
                                        <td>@spi</td>
                                        <td class="fw-semibold">@r.SupplierName</td>
                                        <td class="text-center"><span class="badge bg-secondary">@r.PurchaseCount</span></td>
                                        <td class="text-center">@r.TotalUnits</td>
                                        <td class="text-end amount-cell">@(r.TotalCost.ToRs())</td>
                                        <td class="text-end amount-cell">@(r.TotalMrpValue.ToRs())</td>
                                        <td class="text-end amount-cell positive">@(r.PotentialProfit.ToRs())</td>
                                        <td class="text-end"><span class="badge @(r.MarginPercent >= 20 ? "bg-success" : r.MarginPercent >= 10 ? "bg-warning text-dark" : "bg-danger")">@r.MarginPercent.ToString("N1")%</span></td>
                                    </tr>
                                    spi++;
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }

            @if (Model.MonthlySupplierPurchase != null)
            {
                if (!Model.MonthlySupplierPurchase.Any())
                {
                    <div class="report-empty">No purchases found for this year.</div>
                }
                else
                {
                    var suppliers = Model.MonthlySupplierPurchase.Select(r => r.SupplierName).Distinct().OrderBy(s => s).ToList();
                    var months = Model.MonthlySupplierPurchase.Select(r => r.Month).Distinct().OrderBy(m => m).ToList();
                    <div class="table-responsive">
                        <table class="table table-pro mb-0">
                            <thead>
                                <tr>
                                    <th>Month</th>
                                    @foreach (var s in suppliers)
                                    {
                                        <th class="text-end" style="min-width:100px">@s</th>
                                    }
                                    <th class="text-end fw-bold">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var mo in months)
                                {
                                    var label = new DateTime(Model.MonthlySupplierPurchase.First().Year, mo, 1).ToString("MMM yyyy");
                                    var rowTotal = Model.MonthlySupplierPurchase.Where(r => r.Month == mo).Sum(r => r.TotalAmount);
                                    <tr>
                                        <td class="fw-semibold">@label</td>
                                        @foreach (var s in suppliers)
                                        {
                                            var cell = Model.MonthlySupplierPurchase.FirstOrDefault(r => r.Month == mo && r.SupplierName == s);
                                            <td class="text-end amount-cell">@(cell != null ? "Rs. " + cell.TotalAmount.ToString("N0") : "—")</td>
                                        }
                                        <td class="text-end fw-bold amount-cell">@(rowTotal.ToRs())</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="report-total-row">
                                    <td class="text-end"><strong>Total</strong></td>
                                    @foreach (var s in suppliers)
                                    {
                                        var colTotal = Model.MonthlySupplierPurchase.Where(r => r.SupplierName == s).Sum(r => r.TotalAmount);
                                        <td class="text-end amount-cell"><strong>@(colTotal.ToRs())</strong></td>
                                    }
                                    <td class="text-end amount-cell"><strong>@Model.MonthlySupplierPurchase.Sum(r => r.TotalAmount).ToRs()</strong></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
            }

            @if (Model.SupplierPayables != null)
            {
                <div class="panel-body">
                    <div class="row g-3 mb-4">
                        <div class="col-6 col-md-3">
                            <div class="pnl-box"><div class="pnl-label">Total Payable</div><div class="pnl-value">@(Model.SupplierPayables.TotalAmount.ToRs())</div></div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="pnl-box pnl-profit"><div class="pnl-label">Total Paid</div><div class="pnl-value positive">@(Model.SupplierPayables.TotalPaid.ToRs())</div></div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="pnl-box"><div class="pnl-label">Pending</div><div class="pnl-value negative">@(Model.SupplierPayables.TotalPending.ToRs())</div></div>
                        </div>
                        <div class="col-6 col-md-3">
                            <div class="pnl-box"><div class="pnl-label">Overdue</div><div class="pnl-value @(Model.SupplierPayables.OverdueCount > 0 ? "negative" : "")">@Model.SupplierPayables.OverdueCount entries</div></div>
                        </div>
                    </div>
                </div>
                @if (Model.SupplierPayables.Suppliers.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-pro mb-0">
                            <thead>
                                <tr>
                                    <th>Supplier</th>
                                    <th class="text-center">Entries</th>
                                    <th class="text-end">Total</th>
                                    <th class="text-end">Paid</th>
                                    <th class="text-end">Pending</th>
                                    <th class="text-center">Overdue</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in Model.SupplierPayables.Suppliers)
                                {
                                    <tr>
                                        <td class="fw-semibold">@s.SupplierName</td>
                                        <td class="text-center"><span class="badge bg-secondary">@s.PayableCount</span></td>
                                        <td class="text-end amount-cell">@(s.TotalAmount.ToRs())</td>
                                        <td class="text-end amount-cell positive">@(s.PaidAmount.ToRs())</td>
                                        <td class="text-end amount-cell @(s.PendingAmount > 0 ? "negative" : "")">@(s.PendingAmount.ToRs())</td>
                                        <td class="text-center">
                                            @if (s.OverdueCount > 0)
                                            {
                                                <span class="badge bg-danger">@s.OverdueCount overdue</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">—</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="report-empty">No payables found. Payables are auto-created for credit purchases.</div>
                }
            }

            @if (Model.AuditLogs != null)
            {
                if (!Model.AuditLogs.Any())
                {
                    <div class="report-empty">No audit entries found.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-pro mb-0">
                            <thead>
                                <tr>
                                    <th>Timestamp</th>
                                    <th>User</th>
                                    <th>Action</th>
                                    <th>Entity</th>
                                    <th>Details</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var a in Model.AuditLogs)
                                {
                                    <tr>
                                        <td><small class="text-muted">@a.Timestamp.ToLocalTime().ToString("dd-MM-yyyy HH:mm")</small></td>
                                        <td><small>@(a.UserName ?? a.UserId ?? "System")</small></td>
                                        <td><span class="badge bg-secondary bg-opacity-75">@a.Action</span></td>
                                        <td><small class="text-muted">@(a.EntityType ?? "—") @(a.EntityId.HasValue ? "#" + a.EntityId : "")</small></td>
                                        <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                                            <small class="text-muted" title="@a.NewValue">@(a.NewValue ?? a.OldValue ?? "—")</small>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        const salesTrend = @Html.Raw(Model.SalesTrendJson);
        const topMeds = @Html.Raw(Model.MedicineChartJson);
        const chartFont = '#cbd5e1';
        const chartGrid = 'rgba(255,255,255,0.08)';

        const salesCanvas = document.getElementById('monthlySalesChart');
        const salesEmpty = document.getElementById('salesChartEmpty');
        if (salesTrend.length === 0 || salesTrend.every(x => x.amount === 0)) {
            salesCanvas.classList.add('d-none');
            salesEmpty.classList.remove('d-none');
        } else {
            new Chart(salesCanvas, {
                type: 'bar',
                data: {
                    labels: salesTrend.map(x => x.label),
                    datasets: [{
                        label: 'Sales (Rs.)',
                        data: salesTrend.map(x => x.amount),
                        backgroundColor: 'rgba(14, 165, 233, 0.75)',
                        borderColor: '#38bdf8',
                        borderWidth: 1,
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: true,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            backgroundColor: '#0f2744',
                            titleColor: '#fff',
                            bodyColor: '#cbd5e1',
                            callbacks: { label: ctx => ' Rs. ' + ctx.parsed.y.toLocaleString() }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: { color: '#94a3b8', callback: v => 'Rs.' + v },
                            grid: { color: chartGrid }
                        },
                        x: { ticks: { color: '#94a3b8', maxRotation: 45, font: { size: 10 } }, grid: { display: false } }
                    }
                }
            });
        }

        const medCanvas = document.getElementById('medicinePieChart');
        const medEmpty = document.getElementById('medChartEmpty');
        if (topMeds.length === 0) {
            medCanvas.classList.add('d-none');
            medEmpty.classList.remove('d-none');
        } else {
            new Chart(medCanvas, {
                type: 'doughnut',
                data: {
                    labels: topMeds.map(x => x.medicineName),
                    datasets: [{
                        data: topMeds.map(x => x.totalAmount),
                        backgroundColor: ['#2563EB','#10B981','#F59E0B','#EF4444','#8B5CF6','#06B6D4','#6366F1','#0EA5E9'],
                        borderColor: '#FFFFFF',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: { position: 'bottom', labels: { color: chartFont, boxWidth: 12, padding: 10, font: { size: 11 } } },
                        tooltip: {
                            backgroundColor: '#0f2744',
                            callbacks: { label: ctx => ' Rs. ' + ctx.parsed.toLocaleString() }
                        }
                    }
                }
            });
        }

        @if (Model.ReportTitle != null)
        {
            <text>document.getElementById('reportResults')?.scrollIntoView({ behavior: 'smooth', block: 'start' });</text>
        }
    </script>
}
