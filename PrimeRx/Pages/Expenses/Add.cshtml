@page
@using PrimeRx.Models
@model PrimeRx.Pages.Expenses.AddModel
@{
    ViewData["Title"] = "Add Expense";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <h1 class="page-title mb-0">Add Expense</h1>
    <p class="page-subtitle mb-0">Record a new expense entry</p>
</div>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="panel-card" style="max-width:640px;">
    <div class="panel-header"><i class="bi bi-cash-stack me-2"></i>Expense Details</div>
    <div class="panel-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Input.ExpenseDate" class="form-label">Date</label>
                    <input asp-for="Input.ExpenseDate" class="form-control" type="date" />
                    <span asp-validation-for="Input.ExpenseDate" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.Category" class="form-label">Category</label>
                    <select asp-for="Input.Category" class="form-select">
                        @foreach (var c in ExpenseCategories.All)
                        {
                            <option value="@c">@ExpenseCategories.Display(c)</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.Amount" class="form-label">Amount (Rs.)</label>
                    <div class="input-group">
                        <span class="input-group-text">Rs.</span>
                        <input asp-for="Input.Amount" class="form-control" type="number" step="0.01" min="0.01" />
                    </div>
                    <span asp-validation-for="Input.Amount" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Input.PaidBy" class="form-label">Paid By</label>
                    <input asp-for="Input.PaidBy" class="form-control" placeholder="e.g. Cash from counter" />
                </div>
                <div class="col-12">
                    <label asp-for="Input.Reason" class="form-label">Reason / Description <span class="text-danger">*</span></label>
                    <textarea asp-for="Input.Reason" class="form-control" rows="2"
                              placeholder="e.g. Monthly electricity bill, delivery charges..."></textarea>
                    <span asp-validation-for="Input.Reason" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="Input.Notes" class="form-label">Notes <span class="text-muted small">(optional)</span></label>
                    <input asp-for="Input.Notes" class="form-control" placeholder="Any extra details..." />
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>Save Expense
                </button>
                <button type="reset" class="btn btn-outline-secondary">Clear</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
