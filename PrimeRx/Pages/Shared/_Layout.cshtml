<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PrimeRx</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PrimeRx.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="app-body">
    @if (User.Identity?.IsAuthenticated == true)
    {
        @await Component.InvokeAsync("CompanyHeader")
    }

    <nav class="navbar navbar-expand-lg app-navbar">
        <div class="container-fluid px-4">
            <a class="navbar-brand" asp-page="/Dashboard/Index">
                <span class="brand-logo">Rx</span>
                <span class="brand-text">PrimeRx</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav me-auto gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Dashboard/Index"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Billing/Index"><i class="bi bi-receipt me-1"></i>Billing</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-box-seam me-1"></i>Inventory
                            </a>
                            <ul class="dropdown-menu dropdown-menu-dark">
                                <li><a class="dropdown-item" asp-page="/Inventory/Index"><i class="bi bi-list-ul me-2"></i>Stock View</a></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/AddMedicine"><i class="bi bi-plus-circle me-2"></i>Add Medicine</a></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/Purchase"><i class="bi bi-cart-plus me-2"></i>Purchase Entry</a></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/Adjust"><i class="bi bi-arrow-left-right me-2"></i>Stock Adjustment</a></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/History"><i class="bi bi-clock-history me-2"></i>Transaction History</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/Expiry"><i class="bi bi-exclamation-triangle me-2"></i>Expiry Alerts</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Due/Index"><i class="bi bi-wallet2 me-1"></i>Due</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Reports/Index"><i class="bi bi-bar-chart-line me-1"></i>Reports</a></li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear me-1"></i>Admin
                                </a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item" asp-page="/Admin/Settings/Index"><i class="bi bi-sliders me-2"></i>Settings & Bill Design</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Medicines/Index"><i class="bi bi-capsule me-2"></i>Manage Medicines</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Expenses/Index"><i class="bi bi-cash-stack me-2"></i>Expenses</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Users/Index"><i class="bi bi-people me-2"></i>Staff Accounts</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                }
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link position-relative" asp-page="/Notifications/Index" title="Notifications">
                            <i class="bi bi-bell"></i>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" id="notificationBadge" style="display: none;">
                                0
                            </span>
                        </a>
                    </li>
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    <main class="app-main container-fluid px-4 py-4">
        @RenderBody()
    </main>

    <footer class="app-footer text-center">
        <small>
            PrimeRx Pharmacy Management System &copy; @DateTime.Now.Year | 
            Developed by <a href="https://www.facebook.com/PrimeLogictech" target="_blank">Prime LogicTech</a> | 
            📞 986-7788298 | 📧 primelogictech3@gmail.com
        </small>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
