@inject PrimeRx.Data.ApplicationDbContext RxContext
@{
    var rxCompany = await RxContext.CompanyProfiles.AsNoTracking().SingleOrDefaultAsync();
    var rxLogoPath = rxCompany?.LogoPath;
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PrimeRx</title>
    <!-- Apply saved theme BEFORE paint to prevent flash -->
    <script>
        (function () {
            var t = localStorage.getItem('rxTheme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', t);
        })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/bootstrap-icons.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PrimeRx.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/calculator.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <style>
        .notification-read { background-color: rgba(var(--bs-secondary-rgb), 0.05); }
        .notification-item .dismiss-notif:hover { color: var(--bs-danger) !important; }
    </style>
</head>
<body class="app-body">
    @if (User.Identity?.IsAuthenticated == true)
    {
        @await Component.InvokeAsync("CompanyHeader")
    }

    <nav class="navbar navbar-expand-lg app-navbar">
        <div class="container-fluid px-4">
            <a class="navbar-brand" asp-page="/Dashboard/Index">
                @if (!string.IsNullOrEmpty(rxLogoPath))
                {
                    <img src="@Url.Content(rxLogoPath)" alt="Logo" class="navbar-logo" />
                }
                else
                {
                    <span class="brand-logo">Rx</span>
                }
                <span class="brand-text">PrimeRx</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav me-auto gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Dashboard/Index"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Billing/Index"><i class="bi bi-receipt me-1"></i>Billing</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-box-seam me-1"></i>Inventory
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-page="/Inventory/Index"><i class="bi bi-list-ul me-2"></i>Stock View</a></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/Batches"><i class="bi bi-layers me-2"></i>Batch-wise Stock</a></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/AddMedicine"><i class="bi bi-plus-circle me-2"></i>Add Medicine</a></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/Adjust"><i class="bi bi-arrow-left-right me-2"></i>Stock Adjustment</a></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/StockExchange"><i class="bi bi-send me-2"></i>Stock Exchange (Aaicho Paicho)</a></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/History"><i class="bi bi-clock-history me-2"></i>Transaction History</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/Expiry"><i class="bi bi-exclamation-triangle me-2"></i>Expiry Alerts</a></li>
                            </ul>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-truck me-1"></i>Purchase
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-page="/Purchase/Create"><i class="bi bi-plus-lg me-2"></i>New Purchase</a></li>
                                <li><a class="dropdown-item" asp-page="/Purchase/Index"><i class="bi bi-clock-history me-2"></i>Purchase History</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-page="/Purchase/Return/Create"><i class="bi bi-arrow-return-left me-2"></i>Return to Supplier</a></li>
                                <li><a class="dropdown-item" asp-page="/Purchase/Return/Index"><i class="bi bi-receipt-cutoff me-2"></i>Returns & Credit Notes</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Due/Index"><i class="bi bi-wallet2 me-1"></i>Due</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Due/AgingDues/Index"><i class="bi bi-clock-history me-1"></i>Aging Dues</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Reports/Index"><i class="bi bi-bar-chart-line me-1"></i>Reports</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Expenses/Add"><i class="bi bi-cash-stack me-1"></i>Add Expense</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear me-1"></i>Admin
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-page="/Admin/Settings/Index"><i class="bi bi-sliders me-2"></i>Settings & Bill Design</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/MedicineMaster/Index"><i class="bi bi-capsule me-2"></i>Medicine Master List</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Expenses/Index"><i class="bi bi-cash-stack me-2"></i>Expenses</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Payables/Index"><i class="bi bi-credit-card me-2"></i>Payables</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Suppliers/Index"><i class="bi bi-building me-2"></i>Manage Suppliers</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Users/Index"><i class="bi bi-people me-2"></i>Staff Accounts</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Backup/Index"><i class="bi bi-hdd me-2"></i>Backup &amp; Restore</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/AuditLog/Index"><i class="bi bi-shield-check me-2"></i>Audit Log</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                }
                <ul class="navbar-nav align-items-center gap-2">
                    <!-- Search trigger -->
                    <li class="nav-item">
                        <button type="button" class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1" data-search-trigger title="Search (Ctrl+K)">
                            <i class="bi bi-search"></i>
                            <span class="d-none d-md-inline" style="font-size:0.8rem;">Search</span>
                            <kbd class="d-none d-lg-inline" style="font-size:0.6rem;padding:0.05em 0.3em;">Ctrl K</kbd>
                        </button>
                    </li>
                    <!-- Dark / Light mode toggle -->
                    <li class="nav-item">
                        <button id="themeToggle" type="button" title="Toggle light/dark mode" aria-label="Toggle theme">
                            <i id="themeIcon" class="bi bi-moon-fill"></i>
                        </button>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <!-- Notification bell -->
                        <li class="nav-item dropdown">
                            <a class="nav-link position-relative dropdown-toggle" href="#" id="bellDropdown"
                               role="button" data-bs-toggle="dropdown" aria-expanded="false" title="Notifications">
                                <i class="bi bi-bell"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                      id="notificationBadge" style="display:none;">0</span>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end p-0" style="width:340px;max-height:480px;overflow-y:auto;"
                                 aria-labelledby="bellDropdown">
                                <div class="px-3 py-2 border-bottom d-flex justify-content-between align-items-center gap-2">
                                    <strong style="font-size:.9rem;">Notifications</strong>
                                    <div class="d-flex gap-1">
                                        <button id="markAllReadBtn" class="btn btn-sm btn-outline-secondary" style="font-size:.7rem;padding:1px 6px;" title="Mark all as read">&#10003; All</button>
                                        <button id="dismissAllDoneBtn" class="btn btn-sm btn-outline-secondary" style="font-size:.7rem;padding:1px 6px;" title="Dismiss completed">&#10005; Done</button>
                                        <a asp-page="/Notifications/Index" class="btn btn-sm btn-outline-accent" style="font-size:.7rem;padding:1px 6px;">View all</a>
                                    </div>
                                </div>
                                <div id="bellSummaryItems">
                                    <div class="text-center py-3 text-muted small">Loading…</div>
                                </div>
                                <div class="border-top text-center py-2">
                                    <a asp-page="/Notifications/Index" class="small text-primary">Open Notifications Page</a>
                                </div>
                            </div>
                        </li>
                    }
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    <main class="app-main container-fluid px-4 py-4">
        @RenderBody()
    </main>

    <footer class="app-footer text-center">
        <small>
            PrimeRx Pharmacy Management System &copy; @DateTime.Now.Year |
            Developed by <a href="https://www.facebook.com/PrimeLogictech" target="_blank">Prime LogicTech</a> |
            📞 986-7788298 | 📧 primelogictech3@gmail.com
        </small>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/calculator.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- ── Theme Toggle ─────────────────────────────────── -->
    <script>
    (function () {
        const html   = document.documentElement;
        const btn    = document.getElementById('themeToggle');
        const icon   = document.getElementById('themeIcon');

        function applyTheme(t) {
            html.setAttribute('data-bs-theme', t);
            localStorage.setItem('rxTheme', t);
            icon.className = t === 'dark' ? 'bi bi-moon-fill' : 'bi bi-sun-fill';
            btn.title = t === 'dark' ? 'Switch to Light mode' : 'Switch to Dark mode';
        }

        // Sync icon with current theme on load
        applyTheme(html.getAttribute('data-bs-theme') || 'dark');

        btn.addEventListener('click', function () {
            applyTheme(html.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark');
        });
    })();
    </script>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- ── Notification Bell ──────────────────────────── -->
        <script>
        (function () {
            const badge = document.getElementById('notificationBadge');
            const items = document.getElementById('bellSummaryItems');
            const markAllBtn = document.getElementById('markAllReadBtn');
            const dismissDoneBtn = document.getElementById('dismissAllDoneBtn');

            function escHtml(s) {
                return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
            }

            function typeIcon(type) {
                switch (type) {
                    case 'DueExpiry': return 'bi-wallet2 text-danger';
                    case 'ExpiringMedicine': return 'bi-clock-history text-warning';
                    case 'LowStock': return 'bi-box-seam text-info';
                    case 'PayableDue': return 'bi-credit-card text-secondary';
                    default: return 'bi-bell text-muted';
                }
            }

            function typeLink(type, refType, refId) {
                if (refType === 'Bill') return '/Due/Index';
                if (refType === 'Payable') return '/Admin/Payables/Index';
                if (type === 'ExpiringMedicine') return '/Inventory/Expiry';
                if (type === 'LowStock') return '/Inventory/Index';
                return '/Notifications/Index';
            }

            let notifFailCount = 0;
            async function loadNotifications() {
                try {
                    const res = await fetch('/Notifications?handler=NotificationsJson');
                    if (!res.ok) return;
                    const ct = res.headers.get('content-type') || '';
                    if (!ct.includes('application/json')) return;
                    const d = await res.json();
                    notifFailCount = 0;

                    const unread = d.unreadCount ?? 0;
                    if (unread > 0) {
                        badge.textContent = unread > 99 ? '99+' : unread;
                        badge.style.display = '';
                    } else {
                        badge.style.display = 'none';
                    }

                    let html = '';
                    if (d.notifications && d.notifications.length > 0) {
                        d.notifications.forEach(n => {
                            const dimmed = n.isRead || n.isActionCompleted ? 'opacity-50' : '';
                            const readClass = n.isRead ? 'notification-read' : '';
                            const icon = typeIcon(n.type);
                            const link = typeLink(n.type, n.refType, n.refId);
                            html += `<div class="dropdown-item py-2 border-bottom notification-item ${dimmed} ${readClass}" data-id="${n.id}" data-ref="${n.refType}-${n.refId}">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <a href="${link}" class="text-decoration-none flex-grow-1 min-w-0" onclick="markNotifRead(${n.id})">
                                        <div class="d-flex align-items-center gap-2">
                                            <i class="bi ${icon}"></i>
                                            <div class="min-w-0">
                                                <div class="text-truncate" style="font-size:.82rem;">${escHtml(n.title)}</div>
                                                <div class="text-muted text-truncate" style="font-size:.72rem;">${escHtml(n.message ?? '')}</div>
                                                <div class="text-muted" style="font-size:.65rem;">${escHtml(n.timeAgo)}</div>
                                            </div>
                                        </div>
                                    </a>
                                    <button class="btn btn-sm p-0 border-0 text-muted dismiss-notif flex-shrink-0" style="font-size:.7rem;line-height:1;" data-id="${n.id}" title="Dismiss">&times;</button>
                                </div>
                            </div>`;
                        });
                    } else {
                        html = '<div class="text-center py-3 text-muted small"><i class="bi bi-check-circle text-success me-1"></i>All clear — no pending alerts</div>';
                    }
                    items.innerHTML = html;

                    // Wire dismiss buttons
                    items.querySelectorAll('.dismiss-notif').forEach(btn => {
                        btn.addEventListener('click', async function (e) {
                            e.preventDefault();
                            e.stopPropagation();
                            const id = this.dataset.id;
                            await fetch('/Notifications?handler=Dismiss', {
                                method: 'POST',
                                headers: {'Content-Type':'application/json'},
                                body: JSON.stringify({id: Number(id)})
                            });
                            loadNotifications();
                        });
                    });
                } catch (err) {
                    notifFailCount++;
                    if (notifFailCount <= 2) {
                        items.innerHTML = '<div class="text-center py-3 text-muted small">Could not load notifications</div>';
                    }
                }
            }

            // Mark single notification as read on click
            window.markNotifRead = async function (id) {
                await fetch('/Notifications?handler=MarkRead', {
                    method: 'POST',
                    headers: {'Content-Type':'application/json'},
                    body: JSON.stringify({id: Number(id)})
                });
            };

            // Mark all as read
            if (markAllBtn) {
                markAllBtn.addEventListener('click', async function () {
                    await fetch('/Notifications?handler=MarkAllRead', { method: 'POST' });
                    loadNotifications();
                });
            }

            // Dismiss all completed
            if (dismissDoneBtn) {
                dismissDoneBtn.addEventListener('click', async function () {
                    await fetch('/Notifications?handler=DismissAllCompleted', { method: 'POST' });
                    loadNotifications();
                });
            }

            document.getElementById('bellDropdown')?.addEventListener('show.bs.dropdown', loadNotifications);
            loadNotifications();
            setInterval(loadNotifications, 120000);
        })();
        </script>
    }

    <!-- ── Global Search Overlay ──────────────────────────── -->
    <div class="global-search-overlay" id="globalSearchOverlay">
        <div class="global-search-modal">
            <div class="global-search-input-wrap">
                <i class="bi bi-search"></i>
                <input type="text" class="global-search-input" id="globalSearchInput"
                       placeholder="Search features, pages..." autocomplete="off" spellcheck="false">
                <button class="global-search-close" id="globalSearchClose" type="button" aria-label="Close">&times;</button>
            </div>
            <div class="global-search-results" id="globalSearchResults">
                <div class="gs-empty">Start typing to search...</div>
            </div>
            <div class="global-search-footer">
                <span><kbd>↑↓</kbd> Navigate</span>
                <span><kbd>Enter</kbd> Open</span>
                <span><kbd>Esc</kbd> Close</span>
            </div>
        </div>
    </div>
</body>
</html>
