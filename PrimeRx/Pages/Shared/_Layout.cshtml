<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PrimeRx</title>
    <!-- Apply saved theme BEFORE paint to prevent flash -->
    <script>
        (function () {
            var t = localStorage.getItem('rxTheme') ||
                (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
            document.documentElement.setAttribute('data-bs-theme', t);
        })();
    </script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PrimeRx.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="app-body">
    @if (User.Identity?.IsAuthenticated == true)
    {
        @await Component.InvokeAsync("CompanyHeader")
    }

    <nav class="navbar navbar-expand-lg app-navbar">
        <div class="container-fluid px-4">
            <a class="navbar-brand" asp-page="/Dashboard/Index">
                <span class="brand-logo">Rx</span>
                <span class="brand-text">PrimeRx</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav me-auto gap-lg-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Dashboard/Index"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Billing/Index"><i class="bi bi-receipt me-1"></i>Billing</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-box-seam me-1"></i>Inventory
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-page="/Inventory/Index"><i class="bi bi-list-ul me-2"></i>Stock View</a></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/AddMedicine"><i class="bi bi-plus-circle me-2"></i>Add Medicine</a></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/Purchase"><i class="bi bi-cart-plus me-2"></i>Purchase Entry</a></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/Adjust"><i class="bi bi-arrow-left-right me-2"></i>Stock Adjustment</a></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/History"><i class="bi bi-clock-history me-2"></i>Transaction History</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-page="/Inventory/Expiry"><i class="bi bi-exclamation-triangle me-2"></i>Expiry Alerts</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Due/Index"><i class="bi bi-wallet2 me-1"></i>Due</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Reports/Index"><i class="bi bi-bar-chart-line me-1"></i>Reports</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Expenses/Add"><i class="bi bi-cash-stack me-1"></i>Add Expense</a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear me-1"></i>Admin
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-page="/Admin/Settings/Index"><i class="bi bi-sliders me-2"></i>Settings & Bill Design</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Medicines/Index"><i class="bi bi-capsule me-2"></i>Manage Medicines</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Expenses/Index"><i class="bi bi-cash-stack me-2"></i>Expenses</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Payables/Index"><i class="bi bi-credit-card me-2"></i>Payables</a></li>
                                    <li><a class="dropdown-item" asp-page="/Admin/Users/Index"><i class="bi bi-people me-2"></i>Staff Accounts</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                }
                <ul class="navbar-nav align-items-center gap-2">
                    <!-- Dark / Light mode toggle -->
                    <li class="nav-item">
                        <button id="themeToggle" type="button" title="Toggle light/dark mode" aria-label="Toggle theme">
                            <i id="themeIcon" class="bi bi-moon-fill"></i>
                        </button>
                    </li>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <!-- Notification bell -->
                        <li class="nav-item dropdown">
                            <a class="nav-link position-relative" href="#" id="bellDropdown"
                               role="button" data-bs-toggle="dropdown" aria-expanded="false" title="Notifications">
                                <i class="bi bi-bell"></i>
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                                      id="notificationBadge" style="display:none;">0</span>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end p-0" style="width:320px;max-height:480px;overflow-y:auto;"
                                 aria-labelledby="bellDropdown">
                                <div class="px-3 py-2 border-bottom d-flex justify-content-between align-items-center">
                                    <strong style="font-size:.9rem;">Notifications</strong>
                                    <a asp-page="/Notifications/Index" class="text-primary small">View all</a>
                                </div>
                                <div id="bellSummaryItems">
                                    <div class="text-center py-3 text-muted small">Loading…</div>
                                </div>
                                <div class="border-top text-center py-2">
                                    <a asp-page="/Notifications/Index" class="small text-primary">Open Notifications Page</a>
                                </div>
                            </div>
                        </li>
                    }
                </ul>
                <partial name="_LoginPartial" />
            </div>
        </div>
    </nav>

    <main class="app-main container-fluid px-4 py-4">
        @RenderBody()
    </main>

    <footer class="app-footer text-center">
        <small>
            PrimeRx Pharmacy Management System &copy; @DateTime.Now.Year |
            Developed by <a href="https://www.facebook.com/PrimeLogictech" target="_blank">Prime LogicTech</a> |
            📞 986-7788298 | 📧 primelogictech3@gmail.com
        </small>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- ── Theme Toggle ─────────────────────────────────── -->
    <script>
    (function () {
        const html   = document.documentElement;
        const btn    = document.getElementById('themeToggle');
        const icon   = document.getElementById('themeIcon');

        function applyTheme(t) {
            html.setAttribute('data-bs-theme', t);
            localStorage.setItem('rxTheme', t);
            icon.className = t === 'dark' ? 'bi bi-moon-fill' : 'bi bi-sun-fill';
            btn.title = t === 'dark' ? 'Switch to Light mode' : 'Switch to Dark mode';
        }

        // Sync icon with current theme on load
        applyTheme(html.getAttribute('data-bs-theme') || 'dark');

        btn.addEventListener('click', function () {
            applyTheme(html.getAttribute('data-bs-theme') === 'dark' ? 'light' : 'dark');
        });
    })();
    </script>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <!-- ── Notification Bell ──────────────────────────── -->
        <script>
        (function () {
            const badge = document.getElementById('notificationBadge');
            const items = document.getElementById('bellSummaryItems');

            function escHtml(s) {
                return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
            }

            async function loadBellSummary() {
                try {
                    const res = await fetch('/Notifications?handler=BellSummary');
                    if (!res.ok) return;
                    const d = await res.json();

                    const total = d.totalCount ?? 0;
                    if (total > 0) {
                        badge.textContent = total > 99 ? '99+' : total;
                        badge.style.display = '';
                    } else {
                        badge.style.display = 'none';
                    }

                    let html = '';

                    if (d.customerDues > 0) {
                        html += `<a href="/Due/Index" class="dropdown-item py-2 border-bottom">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-wallet2 text-danger"></i>
                                <span><strong>${d.customerDues}</strong> customer due${d.customerDues > 1 ? 's' : ''} pending</span>
                            </div>
                        </a>`;
                    }
                    if (d.expiring > 0) {
                        html += `<a href="/Inventory/Expiry" class="dropdown-item py-2 border-bottom">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-clock-history text-warning"></i>
                                <span><strong>${d.expiring}</strong> medicine${d.expiring > 1 ? 's' : ''} expiring soon</span>
                            </div>
                        </a>`;
                    }
                    if (d.lowStock > 0) {
                        html += `<a href="/Inventory/Index" class="dropdown-item py-2 border-bottom">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-box-seam text-info"></i>
                                <span><strong>${d.lowStock}</strong> low stock item${d.lowStock > 1 ? 's' : ''}</span>
                            </div>
                        </a>`;
                    }
                    if (d.payables && d.payables.length > 0) {
                        d.payables.forEach(p => {
                            const due = new Date(p.dueDate).toLocaleDateString('en-IN', {day:'2-digit',month:'short',year:'numeric'});
                            const overdueBadge = p.isOverdue ? '<span class="badge bg-danger ms-1" style="font-size:.65rem;">Overdue</span>' : '';
                            html += `<a href="/Admin/Payables/Index" class="dropdown-item py-2 border-bottom">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div><i class="bi bi-credit-card text-secondary me-1"></i><strong>${escHtml(p.supplierName)}</strong>${overdueBadge}</div>
                                        <div class="text-muted" style="font-size:.78rem;">${escHtml(p.invoiceNo ?? '')} · Due ${escHtml(due)}</div>
                                    </div>
                                    <span class="text-danger fw-bold ms-2" style="white-space:nowrap;">Rs. ${Number(p.pendingAmount).toFixed(2)}</span>
                                </div>
                            </a>`;
                        });
                    }
                    if (!html) {
                        html = '<div class="text-center py-3 text-muted small"><i class="bi bi-check-circle text-success me-1"></i>All clear — no pending alerts</div>';
                    }
                    items.innerHTML = html;
                } catch {
                    items.innerHTML = '<div class="text-center py-3 text-muted small">Could not load notifications</div>';
                }
            }

            document.getElementById('bellDropdown')?.addEventListener('show.bs.dropdown', loadBellSummary);
            loadBellSummary();
            setInterval(loadBellSummary, 60000);
        })();
        </script>
    }
</body>
</html>
