@model PrimeRx.Models.CompanyProfile

<div class="company-header-bar">
    <div class="container-fluid px-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
            <div class="d-flex align-items-center gap-3">
                @if (!string.IsNullOrWhiteSpace(Model.LogoPath))
                {
                    <img src="@Url.Content(Model.LogoPath)" alt="@Model.Name" class="company-logo" />
                }
                <div>
                    <div class="company-name">@Model.Name</div>
                    @if (!string.IsNullOrWhiteSpace(Model.Address))
                    {
                        <div class="company-meta">@Model.Address</div>
                    }
                </div>
            </div>
            <div class="company-contact text-md-end">
                @if (!string.IsNullOrWhiteSpace(Model.Phone))
                {
                    <span><i class="bi bi-telephone"></i> @Model.Phone</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.GSTIN))
                {
                    <span class="ms-3"><i class="bi bi-receipt"></i> Regd.no: @Model.GSTIN</span>
                }
            </div>
        </div>
    </div>
</div>
