@{
    var reasons = new[] { "Expired", "Damaged", "Wrong Supply", "Product Recall", "Overstock", "Other" };
}

<div class="modal fade return-modal" id="returnToSupplierModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <svg class="return-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="1 4 1 10 7 10"/>
                    <path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/>
                </svg>
                <h5 class="modal-title">Return to Supplier</h5>
                <span class="supplier-badge" id="returnModalSupplierName">Select Supplier</span>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body">
                <div class="batch-summary">
                    <div class="batch-summary-item">
                        <span class="bs-label">Total Items</span>
                        <span class="bs-value" id="returnItemCount">0</span>
                    </div>
                    <div class="batch-summary-item">
                        <span class="bs-label">Subtotal</span>
                        <span class="bs-value" id="returnBatchSubtotal">Rs. 0.00</span>
                    </div>
                    <div class="batch-summary-item">
                        <span class="bs-label">Batches Selected</span>
                        <span class="bs-value" id="returnBatchCount">0</span>
                    </div>
                </div>

                <div class="return-table-wrapper">
                    <table class="return-table">
                        <thead>
                            <tr>
                                <th style="width:26%">Medicine Name</th>
                                <th style="width:13%">Batch #</th>
                                <th style="width:9%" class="num-header">Qty in Batch</th>
                                <th style="width:10%" class="num-header">Return Qty</th>
                                <th style="width:11%" class="num-header">Purchase Price</th>
                                <th style="width:11%" class="num-header">Return Cost</th>
                                <th style="width:13%">Reason</th>
                                <th style="width:7%"></th>
                            </tr>
                        </thead>
                        <tbody id="returnItemsBody">
                            <tr class="empty-table-msg" id="returnEmptyRow">
                                <td colspan="8">
                                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="opacity:0.3;margin-bottom:0.4rem;"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
                                    <div>Click <strong>"+ Add Another Medicine"</strong> below to add items for return.</div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="add-more-row">
                    <button type="button" class="btn-add-more" onclick="ReturnModal.toggleAddMore(true)">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Add Another Medicine from Same Supplier
                    </button>

                    <div class="add-more-search-container" id="addMoreSearchContainer">
                        <input type="text" class="add-more-search" id="addMoreSearchInput"
                               placeholder="Search medicines from this supplier…"
                               autocomplete="off">
                        <div class="add-more-dropdown" id="addMoreDropdown"></div>
                    </div>
                </div>

                <div class="return-totals">
                    <div class="totals-inner">
                        <div class="total-row">
                            <span class="total-label">Subtotal</span>
                            <span class="total-value" id="returnSubtotal">Rs. 0.00</span>
                        </div>
                        <div class="adjustment-row">
                            <span class="adj-label">Adjust Return Cost</span>
                            <div class="adjustment-group">
                                <button type="button" class="adj-sign-btn" id="returnAdjSign" data-sign="minus"
                                        onclick="ReturnModal.toggleAdjSign()" title="Toggle + / −">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                                </button>
                                <input type="number" class="adj-amount-input" id="returnAdjInput" value="0.00" min="0" step="0.01">
                                <span class="adj-display adj-negative" id="returnAdjDisplay">− Rs. 0.00</span>
                            </div>
                        </div>
                        <div class="total-row total-final">
                            <span class="total-label">Final Return Amount</span>
                            <span class="total-value" id="returnFinalAmount">Rs. 0.00</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-return-cancel" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn-return-confirm" id="returnConfirmBtn" disabled>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    Confirm Return
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('addMoreSearchInput')?.addEventListener('input', function () {
        ReturnModal.filterMedicines(this.value);
    });
</script>
