@page "{id:int}"
@model PrimeRx.Pages.Purchase.EditModel
@{
    ViewData["Title"] = "Edit Purchase";
}

<div class="billing-page">
<div class="page-header mb-3">
    <div>
        <h1 class="page-title">Edit Purchase</h1>
        <p class="page-subtitle">Modify items or supplier details &mdash; stock adjusts automatically</p>
    </div>
    <a asp-page="/Purchase/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post" id="purchaseForm">
    <div class="row g-3">

        <div class="col-lg-8">
            <div class="panel-card mb-3">
                <div class="panel-body">
                    <label class="form-label billing-label">Search Medicine to Add</label>
                    <input type="text" id="medicineSearchText"
                           class="form-control medicine-search-input"
                           placeholder="Type medicine name to search catalog&hellip;"
                           autocomplete="off"
                           role="combobox"
                           aria-expanded="false"
                           aria-autocomplete="list"
                           aria-controls="medicinePopup">
                    <div id="medicinePopup"
                         class="medicine-popup"
                         role="listbox"
                         style="display:none;">
                        <div class="medicine-popup-header">
                            <span style="width:55%">MEDICINE</span>
                            <span style="width:25%">PRICE</span>
                            <span style="width:20%">STOCK</span>
                        </div>
                        <div class="medicine-popup-body" id="medicinePopupBody"></div>
                        <div class="medicine-popup-footer">
                            <span><kbd>&uarr;</kbd><kbd>&darr;</kbd> Navigate</span>
                            <span><kbd>Enter</kbd> Select</span>
                            <span><kbd>Esc</kbd> Close</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="panel-card">
                <div class="panel-header">Purchase Items</div>
                <div class="table-responsive">
                    <table class="table table-pro mb-0" id="itemsTable">
                        <thead>
                            <tr>
                                <th>Medicine</th>
                                <th style="width:90px">Batch #</th>
                                <th style="width:105px">Expiry</th>
                                <th style="width:70px">Qty</th>
                                <th style="width:65px" title="Free/Bonus units">Free</th>
                                <th style="width:95px">Rate</th>
                                <th style="width:65px" title="Discount %">Disc%</th>
                                <th style="width:70px">CC</th>
                                <th style="width:85px">MRP</th>
                                <th style="width:85px">Amount</th>
                                <th style="width:36px"></th>
                            </tr>
                        </thead>
                        <tbody id="itemsBody">
                            <tr id="emptyRow" style="display:none;">
                                <td colspan="11" class="text-center text-muted py-4">Search and add medicines above</td>
                            </tr>
                        </tbody>
                        <tfoot id="tableFoot">
                            <tr class="purchase-total-row">
                                <td colspan="8" class="text-end fw-semibold">Subtotal</td>
                                <td colspan="2" class="fw-bold text-accent" id="subtotalDisplay">Rs. 0.00</td>
                                <td></td>
                            </tr>
                            <tr class="purchase-total-row">
                                <td colspan="8" class="text-end fw-semibold text-danger">Discount</td>
                                <td colspan="2" class="fw-bold text-danger" id="discountDisplay">- Rs. 0.00</td>
                                <td></td>
                            </tr>
                            <tr class="purchase-total-row">
                                <td colspan="8" class="text-end fw-semibold">Conv. Charges (CC)</td>
                                <td colspan="2" class="fw-bold text-accent" id="ccTotalDisplay">Rs. 0.00</td>
                                <td></td>
                            </tr>
                            <tr class="purchase-total-row purchase-grand-total">
                                <td colspan="8" class="text-end fw-semibold">Net Amount</td>
                                <td colspan="2" class="fw-bold text-accent" id="netTotalDisplay">Rs. 0.00</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="panel-card billing-sidebar">
                <div class="panel-header">Supplier Details</div>
                <div class="panel-body">
                    <div class="mb-3">
                        <label class="form-label">Supplier / Company <span class="text-danger">*</span></label>
                        <input asp-for="Input.SupplierName" class="form-control"
                               list="supplierList" autocomplete="off" />
                        <datalist id="supplierList">
                            @foreach (var s in Model.KnownSuppliers)
                            {
                                <option value="@s" />
                            }
                        </datalist>
                        <span asp-validation-for="Input.SupplierName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Supplier Phone</label>
                        <input asp-for="Input.SupplierPhone" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Invoice Number</label>
                        <input asp-for="Input.InvoiceNumber" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Purchase Date</label>
                        <input asp-for="Input.PurchaseDate" class="form-control" type="date" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea asp-for="Input.Notes" class="form-control" rows="2"></textarea>
                    </div>

                    <hr class="billing-divider" />
                    <div class="billing-total-row"><span>Subtotal</span><span id="sidebarSubtotal">Rs. 0.00</span></div>
                    <div class="billing-total-row text-danger"><span>Discount</span><span id="sidebarDiscount">- Rs. 0.00</span></div>
                    <div class="billing-total-row"><span>Total CC</span><span id="sidebarCC">Rs. 0.00</span></div>
                    <div class="billing-total-row billing-total-final mb-3">
                        <span>Net Amount</span>
                        <span id="sidebarNetTotal">Rs. 0.00</span>
                    </div>

                    <input type="hidden" id="itemsJson" name="ItemsJson" value="[]" />
                    <button type="submit" class="btn btn-accent btn-lg w-100" id="saveBtn" disabled>
                        <i class="bi bi-save me-1"></i>Save Changes
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

<!-- Floating medicine search popup (position:fixed, z-index:9999) -->
<div id="medicinePopup" class="medicine-popup" style="display:none;position:fixed;">
    <div class="medicine-popup-header">
        <span style="width:55%">MEDICINE</span>
        <span style="width:25%">PRICE</span>
        <span style="width:20%">STOCK</span>
    </div>
    <div id="medicinePopupBody" class="medicine-popup-body"></div>
    <div class="medicine-popup-footer">
        <span><kbd>&uarr;</kbd><kbd>&darr;</kbd> Navigate</span>
        <span><kbd>Enter</kbd> Select</span>
        <span><kbd>Esc</kbd> Close</span>
    </div>
</div>

<!-- Floating Calculator -->
<div id="floatingCalc" class="floating-calc" style="display:none">
    <div class="calc-grid">
        <button type="button" class="calc-btn" data-calc="7">7</button>
        <button type="button" class="calc-btn" data-calc="8">8</button>
        <button type="button" class="calc-btn" data-calc="9">9</button>
        <button type="button" class="calc-btn calc-clear" data-calc="C">C</button>
        <button type="button" class="calc-btn" data-calc="4">4</button>
        <button type="button" class="calc-btn" data-calc="5">5</button>
        <button type="button" class="calc-btn" data-calc="6">6</button>
        <button type="button" class="calc-btn calc-back" data-calc="&#x232B;">&#x232B;</button>
        <button type="button" class="calc-btn" data-calc="1">1</button>
        <button type="button" class="calc-btn" data-calc="2">2</button>
        <button type="button" class="calc-btn" data-calc="3">3</button>
        <button type="button" class="calc-btn calc-enter" data-calc="Enter">Enter</button>
        <button type="button" class="calc-btn" data-calc="0">0</button>
        <button type="button" class="calc-btn" data-calc=".">.</button>
        <button type="button" class="calc-btn calc-plus" data-calc="+">+</button>
        <button type="button" class="calc-btn calc-minus" data-calc="-">-</button>
    </div>
</div>

<!-- Batch Info Panel -->
<div id="batchInfoPanel" class="batch-info-panel" style="display:none;">
    <div class="batch-info-header">Batch Information</div>
    <div class="batch-info-body" id="batchInfoBody"></div>
</div>

</div>

@section Styles {
    <link rel="stylesheet" href="~/css/billing.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/purchase.css" asp-append-version="true" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    const MARGIN_PERCENT = @Model.MarginPercent;
    const EXISTING_ITEMS = @Html.Raw(Model.ExistingItemsJson);
    </script>
    <script src="~/js/purchase.js" asp-append-version="true"></script>
}
