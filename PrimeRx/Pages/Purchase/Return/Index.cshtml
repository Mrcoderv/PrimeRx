@page
@model PrimeRx.Pages.Purchase.Return.IndexModel
@{
    ViewData["Title"] = "Purchase Returns";
}

<div class="page-header mb-3">
    <div>
        <h1 class="page-title">Purchase Returns &amp; Credit Notes</h1>
        <p class="page-subtitle">Stock returned to suppliers and credit notes issued</p>
    </div>
    <a asp-page="/Purchase/Return/Create" class="btn btn-accent"><i class="bi bi-arrow-return-left me-1"></i>New Return</a>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success alert-dismissible fade show">
        @Model.Message <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-3 mb-3">
    <div class="col-md-4">
        <div class="panel-card p-3">
            <div class="text-muted small">Total Returns</div>
            <div class="fs-4 fw-bold">@Model.Returns.Count</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="panel-card p-3">
            <div class="text-muted small">Returned Value</div>
            <div class="fs-4 fw-bold">@Model.Returns.Sum(r => r.TotalAmount).ToRs()</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="panel-card p-3">
            <div class="text-muted small">Available Credit (all suppliers)</div>
            <div class="fs-4 fw-bold text-success">@Model.CreditNotes.Sum(c => c.AvailableAmount).ToRs()</div>
        </div>
    </div>
</div>

<div class="panel-card mb-3">
    <div class="panel-header">Returns</div>
    <div class="table-responsive">
        <table class="table table-pro mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Supplier</th>
                    <th>Invoice #</th>
                    <th>Reason</th>
                    <th class="text-center">Items</th>
                    <th class="text-end">Amount</th>
                    <th>Recorded By</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Returns.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No returns recorded yet</td></tr>
                }
                @foreach (var r in Model.Returns)
                {
                    <tr>
                        <td>@r.ReturnDate.ToString("dd MMM yyyy")</td>
                        <td class="fw-semibold">@r.SupplierName</td>
                        <td>@(r.InvoiceNumber ?? "—")</td>
                        <td><span class="badge bg-secondary">@PrimeRx.Models.PurchaseReturnReasons.Display(r.Reason)</span></td>
                        <td class="text-center">@r.Items.Count</td>
                        <td class="text-end fw-semibold">@(r.TotalAmount.ToRs())</td>
                        <td><small class="text-muted">@(r.CreatedBy ?? "—")</small></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="panel-card">
    <div class="panel-header">Credit Notes</div>
    <div class="table-responsive">
        <table class="table table-pro mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Supplier</th>
                    <th class="text-end">Amount</th>
                    <th class="text-end">Used</th>
                    <th class="text-end">Available</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.CreditNotes.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No credit notes yet</td></tr>
                }
                @foreach (var c in Model.CreditNotes)
                {
                    <tr>
                        <td>@c.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td class="fw-semibold">@c.SupplierName</td>
                        <td class="text-end">@(c.Amount.ToRs())</td>
                        <td class="text-end">@(c.UsedAmount.ToRs())</td>
                        <td class="text-end fw-semibold text-success">@(c.AvailableAmount.ToRs())</td>
                        <td>
                            @{
                                var badgeClass = c.Status switch
                                {
                                    PrimeRx.Models.CreditNoteStatus.Available => "bg-success",
                                    PrimeRx.Models.CreditNoteStatus.PartiallyUsed => "bg-warning text-dark",
                                    _ => "bg-secondary"
                                };
                            }
                            <span class="badge @badgeClass">@c.Status</span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
