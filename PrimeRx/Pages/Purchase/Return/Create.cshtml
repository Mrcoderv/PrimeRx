@page
@model PrimeRx.Pages.Purchase.Return.CreateModel
@{
    ViewData["Title"] = "Return to Supplier";
}

<div class="page-header mb-3">
    <div>
        <h1 class="page-title">Return to Supplier</h1>
        <p class="page-subtitle">Send expired/damaged/wrong-supply stock back and issue a credit note</p>
    </div>
    <a asp-page="/Purchase/Return/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post" id="returnForm">
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="panel-card mb-3">
                <div class="panel-body">
                    <label class="form-label billing-label">Search Medicine to Return</label>
                    <div class="position-relative">
                        <input type="text" id="medicineSearchText"
                               class="form-control medicine-search-input"
                               placeholder="Type medicine name…"
                               autocomplete="off">
                        <div id="medicineSearchDropdown" class="medicine-dropdown" style="display:none;">
                            <div class="medicine-dropdown-header">
                                <span style="width:55%">NAME</span>
                                <span style="width:25%">GENERIC</span>
                                <span style="width:20%">STOCK</span>
                            </div>
                            <div class="medicine-dropdown-body" id="medicineDropdownBody"></div>
                            <div class="medicine-dropdown-footer">
                                <span>↑ ↓ Navigate</span><span>Enter Select</span><span>Esc Close</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="panel-card">
                <div class="panel-header">Items to Return</div>
                <div class="table-responsive">
                    <table class="table table-pro mb-0" id="itemsTable">
                        <thead>
                            <tr>
                                <th>Medicine</th>
                                <th style="width:110px">Batch #</th>
                                <th style="width:80px">Qty</th>
                                <th style="width:120px">Purchase Price</th>
                                <th style="width:110px">Amount</th>
                                <th style="width:40px"></th>
                            </tr>
                        </thead>
                        <tbody id="itemsBody">
                            <tr id="emptyRow">
                                <td colspan="6" class="text-center text-muted py-4">Search and add medicines above</td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="4" class="text-end fw-semibold">Total Return Amount</td>
                                <td class="fw-bold text-accent" id="totalDisplay">Rs. 0.00</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="panel-card billing-sidebar">
                <div class="panel-header">Return Details</div>
                <div class="panel-body">
                    <div class="mb-3">
                        <label class="form-label">Supplier / Company <span class="text-danger">*</span></label>
                        <input asp-for="Input.SupplierName" class="form-control" placeholder="Supplier name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Original Invoice Number</label>
                        <input asp-for="Input.InvoiceNumber" class="form-control" placeholder="Optional" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Return Date</label>
                        <input asp-for="Input.ReturnDate" class="form-control" type="date" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Reason <span class="text-danger">*</span></label>
                        <select asp-for="Input.Reason" class="form-select">
                            @foreach (var r in Model.Reasons)
                            {
                                <option value="@r">@PrimeRx.Models.PurchaseReturnReasons.Display(r)</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea asp-for="Input.Notes" class="form-control" rows="2" placeholder="Optional remarks…"></textarea>
                    </div>

                    <hr class="billing-divider" />
                    <div class="billing-total-row billing-total-final mb-3">
                        <span>Total</span>
                        <span id="sidebarTotal">Rs. 0.00</span>
                    </div>
                    <div class="alert alert-info py-2 small mb-3">
                        <i class="bi bi-info-circle me-1"></i>
                        Stock will be reduced and a <strong>credit note</strong> will be issued for this supplier.
                    </div>

                    <input type="hidden" id="itemsJson" name="ItemsJson" value="[]" />
                    <button type="submit" class="btn btn-accent btn-lg w-100" id="saveBtn" disabled>
                        <i class="bi bi-arrow-return-left me-1"></i>Record Return
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Styles {
    <link rel="stylesheet" href="~/css/billing.css" asp-append-version="true" />
}

@section Scripts {
<script>
(function () {
    let items = [];
    let searchResults = [];
    let selectedIndex = -1;
    let searchTimer = null;

    const searchInput   = document.getElementById('medicineSearchText');
    const dropdown       = document.getElementById('medicineSearchDropdown');
    const dropdownBody   = document.getElementById('medicineDropdownBody');
    const itemsBody      = document.getElementById('itemsBody');
    const emptyRow        = document.getElementById('emptyRow');
    const totalDisplay   = document.getElementById('totalDisplay');
    const sidebarTotal   = document.getElementById('sidebarTotal');
    const itemsJsonInput = document.getElementById('itemsJson');
    const saveBtn         = document.getElementById('saveBtn');

    searchInput.addEventListener('input', () => {
        clearTimeout(searchTimer);
        const term = searchInput.value.trim();
        if (term.length < 2) { hideDropdown(); return; }
        searchTimer = setTimeout(() => fetchMedicines(term), 200);
    });

    searchInput.addEventListener('keydown', e => {
        if (!dropdown.style || dropdown.style.display === 'none') return;
        if (e.key === 'ArrowDown') { e.preventDefault(); moveSel(1); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); moveSel(-1); }
        else if (e.key === 'Enter') { e.preventDefault(); if (selectedIndex >= 0) selectMedicine(searchResults[selectedIndex]); }
        else if (e.key === 'Escape') hideDropdown();
    });

    document.addEventListener('click', e => {
        if (!dropdown.contains(e.target) && e.target !== searchInput) hideDropdown();
    });

    async function fetchMedicines(term) {
        try {
            const res = await fetch(`?handler=Search&term=${encodeURIComponent(term)}`);
            searchResults = await res.json();
            renderDropdown();
        } catch { hideDropdown(); }
    }

    function renderDropdown() {
        if (!searchResults.length) { hideDropdown(); return; }
        selectedIndex = -1;
        dropdownBody.innerHTML = searchResults.map((m, i) =>
            `<div class="medicine-dropdown-item" data-idx="${i}">
                <span style="width:55%">${esc(m.name)}${m.genericName ? `<br><small class="text-muted">${esc(m.genericName)}</small>` : ''}</span>
                <span style="width:25%"><small class="text-muted">${m.purchasePrice > 0 ? 'Rs.'+m.purchasePrice.toFixed(2) : '—'}</small></span>
                <span style="width:20%"><small>${m.stockQuantity}</small></span>
            </div>`
        ).join('');
        dropdownBody.querySelectorAll('.medicine-dropdown-item').forEach(el => {
            el.addEventListener('mousedown', e => { e.preventDefault(); selectMedicine(searchResults[+el.dataset.idx]); });
        });
        dropdown.style.display = '';
        if (searchResults.length > 0) {
            moveSel(1);
        }
    }

    function moveSel(dir) {
        const rows = dropdownBody.querySelectorAll('.medicine-dropdown-item');
        rows.forEach(r => r.classList.remove('active'));
        selectedIndex = Math.max(0, Math.min(rows.length - 1, selectedIndex + dir));
        rows[selectedIndex]?.classList.add('active');
        rows[selectedIndex]?.scrollIntoView({ block: 'nearest' });
    }

    function hideDropdown() {
        dropdown.style.display = 'none';
        searchResults = [];
        selectedIndex = -1;
    }

    function selectMedicine(m) {
        hideDropdown();
        searchInput.value = '';
        if (items.find(i => i.medicineId === m.id)) { return; }

        items.push({
            medicineId: m.id,
            medicineName: m.name,
            batchNumber: m.batchNumber || '',
            quantity: 1,
            purchasePrice: m.purchasePrice || 0
        });
        renderTable();
        searchInput.focus();
    }

    function renderTable() {
        if (!items.length) {
            emptyRow.style.display = '';
            itemsBody.innerHTML = '';
            itemsBody.appendChild(emptyRow);
            updateTotals();
            return;
        }
        emptyRow.style.display = 'none';

        itemsBody.innerHTML = items.map((item, idx) => `
            <tr data-idx="${idx}">
                <td class="fw-semibold">${esc(item.medicineName)}</td>
                <td>
                    <input type="text" class="form-control form-control-sm"
                           value="${esc(item.batchNumber)}" placeholder="Batch #"
                           onchange="window.__retUpdateField(${idx},'batchNumber',this.value)" />
                </td>
                <td>
                    <input type="number" class="form-control form-control-sm text-center"
                           value="${item.quantity}" min="1"
                           onchange="window.__retUpdateField(${idx},'quantity',+this.value||1)" />
                </td>
                <td>
                    <input type="number" class="form-control form-control-sm"
                           value="${item.purchasePrice}" min="0" step="0.01"
                           onchange="window.__retUpdateField(${idx},'purchasePrice',+this.value||0)" />
                </td>
                <td class="fw-semibold text-end align-middle">
                    Rs. ${(item.quantity * item.purchasePrice).toFixed(2)}
                </td>
                <td class="align-middle">
                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="window.__retRemove(${idx})">
                        <i class="bi bi-x"></i>
                    </button>
                </td>
            </tr>
        `).join('');

        updateTotals();
    }

    function updateTotals() {
        const total = items.reduce((s, i) => s + i.quantity * i.purchasePrice, 0);
        const formatted = 'Rs. ' + total.toFixed(2);
        totalDisplay.textContent = formatted;
        sidebarTotal.textContent = formatted;
        saveBtn.disabled = items.length === 0;
        itemsJsonInput.value = JSON.stringify(items);
    }

    window.__retUpdateField = function (idx, field, value) {
        items[idx][field] = value;
        renderTable();
    };

    window.__retRemove = function (idx) {
        items.splice(idx, 1);
        renderTable();
    };

    function esc(str) {
        return String(str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
})();
</script>
}
