@page
@model PrimeRx.Pages.Purchase.CreateModel
@{
    ViewData["Title"] = "New Purchase";
}

<div class="page-header mb-3">
    <div>
        <h1 class="page-title">New Purchase</h1>
        <p class="page-subtitle">Record a multi-item stock purchase from a supplier</p>
    </div>
    <a asp-page="/Purchase/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post" id="purchaseForm">
    <div class="row g-3">

        <!-- Left: Medicine search + items table -->
        <div class="col-lg-8">
            <div class="panel-card mb-3">
                <div class="panel-body">
                    <label class="form-label billing-label">Search Medicine to Add</label>
                    <div class="position-relative">
                        <input type="text" id="medicineSearchText"
                               class="form-control medicine-search-input"
                               placeholder="Type medicine name…"
                               autocomplete="off">
                        <div id="medicineSearchDropdown" class="medicine-dropdown" style="display:none;">
                            <div class="medicine-dropdown-header">
                                <span style="width:55%">NAME</span>
                                <span style="width:25%">GENERIC</span>
                                <span style="width:20%">STOCK</span>
                            </div>
                            <div class="medicine-dropdown-body" id="medicineDropdownBody"></div>
                            <div class="medicine-dropdown-footer">
                                <span>↑ ↓ Navigate</span><span>Enter Select</span><span>Esc Close</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="panel-card">
                <div class="panel-header">Purchase Items</div>
                <div class="table-responsive">
                    <table class="table table-pro mb-0" id="itemsTable">
                        <thead>
                            <tr>
                                <th>Medicine</th>
                                <th style="width:95px">Batch #</th>
                                <th style="width:115px">Expiry</th>
                                <th style="width:60px">Qty</th>
                                <th style="width:60px" title="Free/Bonus units">Free</th>
                                <th style="width:105px">Purchase Price</th>
                                <th style="width:75px" title="Discount %">Disc %</th>
                                <th style="width:95px">MRP</th>
                                <th style="width:95px">Amount</th>
                                <th style="width:40px"></th>
                            </tr>
                        </thead>
                        <tbody id="itemsBody">
                            <tr id="emptyRow">
                                <td colspan="10" class="text-center text-muted py-4">Search and add medicines above</td>
                            </tr>
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="8" class="text-end fw-semibold">Total Purchase Amount</td>
                                <td class="fw-bold text-accent" id="totalDisplay">Rs. 0.00</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <!-- Right: Supplier details + save -->
        <div class="col-lg-4">
            <div class="panel-card billing-sidebar">
                <div class="panel-header">Supplier Details</div>
                <div class="panel-body">
                    <div class="mb-3">
                        <label class="form-label">Supplier / Company <span class="text-danger">*</span></label>
                        <select asp-for="Input.SupplierName" class="form-select" id="supplierName"
                                onchange="onSupplierChange(this.value)">
                            <option value="">— Select or type a supplier —</option>
                            @foreach (var s in Model.KnownSuppliers)
                            {
                                <option value="@s.Name" data-phone="@s.Phone" data-creditdays="@s.CreditDays">@s.Name</option>
                            }
                        </select>
                        <input type="text" class="form-control mt-1" id="supplierNameCustom"
                               placeholder="Or type a new supplier name…"
                               style="display:none;" />
                        <div class="mt-1">
                            <a href="#" class="small" id="toggleCustomSupplier"
                               onclick="toggleCustomSupplier(event)">Enter supplier not in list</a>
                            <a asp-page="/Admin/Suppliers/Add" class="small ms-2 text-muted" target="_blank">
                                <i class="bi bi-plus-circle me-1"></i>Add New Supplier
                            </a>
                        </div>
                        <span asp-validation-for="Input.SupplierName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Supplier Phone</label>
                        <input asp-for="Input.SupplierPhone" class="form-control" id="supplierPhone" placeholder="Auto-filled from supplier" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Invoice Number</label>
                        <input asp-for="Input.InvoiceNumber" class="form-control" placeholder="Supplier invoice #" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Purchase Date</label>
                        <input asp-for="Input.PurchaseDate" class="form-control" type="date" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Payment Type <span class="text-danger">*</span></label>
                        <select asp-for="Input.PaymentType" class="form-select" id="paymentType"
                                onchange="onPaymentTypeChange(this.value)">
                            <option value="Cash">Cash</option>
                            <option value="Credit">Credit</option>
                        </select>
                    </div>
                    <div class="mb-3" id="creditDaysRow" style="display:none;">
                        <label class="form-label">Credit Days</label>
                        <div class="input-group">
                            <input asp-for="Input.CreditDays" class="form-control" type="number" id="creditDaysInput"
                                   min="1" max="365" placeholder="e.g. 30" />
                            <span class="input-group-text">days</span>
                        </div>
                        <div class="form-text" id="dueDateHint"></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea asp-for="Input.Notes" class="form-control" rows="2" placeholder="Optional remarks…"></textarea>
                    </div>

                    <hr class="billing-divider" />
                    <div class="billing-total-row billing-total-final mb-3">
                        <span>Total</span>
                        <span id="sidebarTotal">Rs. 0.00</span>
                    </div>
                    <div id="creditBadge" class="alert alert-warning py-2 small mb-3" style="display:none;">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Credit purchase — a payable will be auto-created in <strong>Payables</strong>.
                    </div>

                    <input type="hidden" id="itemsJson" name="ItemsJson" value="[]" />
                    <button type="submit" class="btn btn-accent btn-lg w-100" id="saveBtn" disabled>
                        <i class="bi bi-save me-1"></i>Save Purchase
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Styles {
    <link rel="stylesheet" href="~/css/billing.css" asp-append-version="true" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
    const MARGIN_PERCENT = @Model.MarginPercent;

    function onSupplierChange(val) {
        const sel = document.getElementById('supplierName');
        const opt = sel.querySelector(`option[value="${CSS.escape(val)}"]`);
        if (opt) {
            const phone = opt.dataset.phone;
            const days  = opt.dataset.creditdays;
            if (phone) document.getElementById('supplierPhone').value = phone;
            if (days && document.getElementById('creditDaysInput').value === '')
                document.getElementById('creditDaysInput').value = days;
            updateDueDateHint();
        }
    }

    function toggleCustomSupplier(e) {
        e.preventDefault();
        const sel    = document.getElementById('supplierName');
        const custom = document.getElementById('supplierNameCustom');
        const link   = document.getElementById('toggleCustomSupplier');
        const isHidden = custom.style.display === 'none';
        if (isHidden) {
            sel.style.display = 'none';
            custom.style.display = '';
            custom.focus();
            link.textContent = 'Pick from list';
            custom.oninput = function() {
                sel.value = '';
            };
        } else {
            sel.style.display = '';
            custom.style.display = 'none';
            link.textContent = 'Enter supplier not in list';
        }
    }

    document.getElementById('purchaseForm').addEventListener('submit', function() {
        const custom = document.getElementById('supplierNameCustom');
        if (custom.style.display !== 'none' && custom.value.trim()) {
            document.getElementById('supplierName').removeAttribute('name');
            const hidden = document.createElement('input');
            hidden.type = 'hidden';
            hidden.name = 'Input.SupplierName';
            hidden.value = custom.value.trim();
            this.appendChild(hidden);
        }
    });

    function onPaymentTypeChange(val) {
        const creditRow  = document.getElementById('creditDaysRow');
        const creditBadge = document.getElementById('creditBadge');
        if (val === 'Credit') {
            creditRow.style.display = '';
            creditBadge.style.display = '';
            if (!document.getElementById('creditDaysInput').value) {
                document.getElementById('creditDaysInput').value = 30;
            }
            updateDueDateHint();
        } else {
            creditRow.style.display = 'none';
            creditBadge.style.display = 'none';
        }
    }

    function updateDueDateHint() {
        const days = parseInt(document.getElementById('creditDaysInput')?.value) || 0;
        if (days > 0) {
            const due = new Date();
            due.setDate(due.getDate() + days);
            document.getElementById('dueDateHint').textContent =
                'Due date: ' + due.toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'});
        }
    }

    document.getElementById('creditDaysInput')?.addEventListener('input', updateDueDateHint);
    </script>
    <script src="~/js/purchase.js" asp-append-version="true"></script>
}
