@page
@model PrimeRx.Pages.Admin.AuditLog.IndexModel
@{
    ViewData["Title"] = "Audit Log";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Audit Log</h1>
        <p class="page-subtitle">Complete trail of all sensitive operations</p>
    </div>
</div>

<div class="panel-card">
    <div class="panel-header d-flex justify-content-between align-items-center">
        <h5><i class="bi bi-shield-check me-2"></i>Recent Activity</h5>
        <span class="badge bg-secondary">Last @Model.Logs.Count entries</span>
    </div>
    <div class="table-responsive">
        <table class="table table-pro mb-0">
            <thead>
                <tr>
                    <th>Timestamp</th>
                    <th>User</th>
                    <th>Action</th>
                    <th>Entity</th>
                    <th>IP Address</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Logs.Count == 0)
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No audit entries recorded yet.</td>
                    </tr>
                }
                else
                {
                    @foreach (var log in Model.Logs)
                    {
                        <tr>
                            <td class="text-nowrap">@log.Timestamp.ToLocalTime().ToString("dd-MM-yyyy HH:mm:ss")</td>
                            <td>@(log.UserName ?? log.UserId ?? "—")</td>
                            <td>
                                <span class="badge bg-@GetActionBadge(log.Action)">@log.Action</span>
                            </td>
                            <td>
                                @if (log.EntityType != null)
                                {
                                    <span class="text-muted small">@log.EntityType</span>
                                    @if (log.EntityId.HasValue)
                                    {
                                        <span class="ms-1">#@log.EntityId</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-muted small">@(log.IPAddress ?? "—")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@functions {
    static string GetActionBadge(string action) => action.ToLower() switch
    {
        var a when a.Contains("delete") || a.Contains("cancel") => "danger",
        var a when a.Contains("create") || a.Contains("add") || a.Contains("bill") => "success",
        var a when a.Contains("edit") || a.Contains("update") || a.Contains("restore") => "warning",
        var a when a.Contains("login") || a.Contains("export") || a.Contains("backup") => "info",
        _ => "secondary"
    };
}
