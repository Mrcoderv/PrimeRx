@page
@model PrimeRx.Pages.Admin.Medicines.CreateModel
@{
    ViewData["Title"] = "Add Medicine";
}

<h2 class="mb-3">Add Medicine</h2>

<div class="card shadow-sm col-lg-8">
    <div class="card-body">
        <form method="post">
            <partial name="_MedicineForm" model="Model.Medicine" />
            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-page="/Admin/Medicines/Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
