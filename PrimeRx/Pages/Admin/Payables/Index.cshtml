@page
@using PrimeRx.Models
@model PrimeRx.Pages.Admin.Payables.IndexModel
@{
    ViewData["Title"] = "Payables";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Payables</h1>
        <p class="page-subtitle">Track and settle amounts owed to suppliers</p>
    </div>
    <a asp-page="/Admin/Payables/Create" class="btn btn-accent">
        <i class="bi bi-plus-circle me-1"></i>Add Payable
    </a>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="bi bi-check-circle me-2"></i>@Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Summary Cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-danger">
            <div class="stat-label">Total Pending</div>
            <div class="stat-value">Rs. @Model.TotalPending.ToString("N0")</div>
            <div class="stat-foot">Unpaid balance</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-warning">
            <div class="stat-label">Overdue</div>
            <div class="stat-value">@Model.OverdueCount</div>
            <div class="stat-foot">Rs. @Model.OverdueAmount.ToString("N0") outstanding</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-info">
            <div class="stat-label">Due in 7 Days</div>
            <div class="stat-value">@Model.DueSoonCount</div>
            <div class="stat-foot">Upcoming payments</div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="stat-card stat-success">
            <div class="stat-label">Paid This Month</div>
            <div class="stat-value">Rs. @Model.PaidThisMonth.ToString("N0")</div>
            <div class="stat-foot">Settled in @DateTime.Today.ToString("MMMM")</div>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="panel-card mb-4">
    <div class="panel-body">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-end">
            <div>
                <label class="form-label small mb-1">Supplier</label>
                <input type="text" name="supplier" value="@Model.SupplierSearch"
                       placeholder="Search supplier…" class="form-control form-control-sm" style="min-width:180px" />
            </div>
            <div>
                <label class="form-label small mb-1">Status</label>
                <select name="filter" class="form-select form-select-sm" style="min-width:130px">
                    @foreach (var opt in new[] { "All", "Pending", "Partial", "Overdue", "Paid" })
                    {
                        <option value="@opt" selected="@(Model.Filter == opt)">@opt</option>
                    }
                </select>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-accent btn-sm">
                    <i class="bi bi-funnel me-1"></i>Filter
                </button>
                <a asp-page="/Admin/Payables/Index" class="btn btn-outline-secondary btn-sm">Clear</a>
            </div>
        </form>
    </div>
</div>

<!-- Table -->
<div class="panel-card">
    <div class="panel-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            <i class="bi bi-credit-card me-2"></i>
            @(Model.Filter == "All" && string.IsNullOrEmpty(Model.SupplierSearch) ? "All Payables" : "Filtered Results")
        </h5>
        <span class="badge bg-secondary">@Model.Payables.Count record(s)</span>
    </div>
    <div class="p-0 panel-body-flush">
        <div class="table-responsive">
            <table class="table table-pro mb-0">
                <thead>
                    <tr>
                        <th>Supplier</th>
                        <th>Invoice #</th>
                        <th>Description</th>
                        <th>Due Date</th>
                        <th class="text-end">Total</th>
                        <th class="text-end">Paid</th>
                        <th class="text-end">Pending</th>
                        <th>Status</th>
                        <th style="width:160px"></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Payables.Any())
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-5">
                                <i class="bi bi-inbox display-6 d-block mb-2 opacity-40"></i>
                                No payables found.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var p in Model.Payables)
                        {
                            <tr class="@(p.IsOverdue ? "table-overdue" : "")">
                                <td><strong>@p.SupplierName</strong></td>
                                <td class="text-muted small">@(p.InvoiceNo ?? "—")</td>
                                <td class="text-muted small">@(p.Description ?? "—")</td>
                                <td>
                                    <span class="@(p.IsOverdue ? "text-danger fw-semibold" : "")">
                                        @p.DueDate.ToString("dd MMM yyyy")
                                    </span>
                                    @if (p.IsOverdue)
                                    {
                                        <span class="badge bg-danger ms-1">Overdue</span>
                                    }
                                    else if ((p.DueDate - DateTime.Today).TotalDays <= 7 && p.Status != PayableStatus.Paid)
                                    {
                                        <span class="badge bg-warning text-dark ms-1">Soon</span>
                                    }
                                </td>
                                <td class="text-end">Rs. @p.Amount.ToString("N2")</td>
                                <td class="text-end" style="color:var(--success)">Rs. @p.PaidAmount.ToString("N2")</td>
                                <td class="text-end fw-bold" style="color:var(--danger)">Rs. @p.PendingAmount.ToString("N2")</td>
                                <td>
                                    @{
                                        var badgeClass = p.Status switch
                                        {
                                            "Paid" => "bg-success",
                                            "Partial" => "bg-warning text-dark",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@p.Status</span>
                                </td>
                                <td>
                                    @if (p.Status != PayableStatus.Paid)
                                    {
                                        <div class="d-flex gap-1">
                                            <button type="button" class="btn btn-sm btn-outline-success"
                                                    data-bs-toggle="modal" data-bs-target="#payModal"
                                                    data-id="@p.Id" data-name="@p.SupplierName"
                                                    data-pending="@p.PendingAmount.ToString("F2")"
                                                    title="Record partial payment">
                                                <i class="bi bi-cash me-1"></i>Pay
                                            </button>
                                            <form method="post" asp-page-handler="MarkPaid" asp-route-id="@p.Id"
                                                  class="d-inline"
                                                  onsubmit="return confirm('Mark full amount as paid for @p.SupplierName?')">
                                                <button type="submit" class="btn btn-sm btn-success" title="Mark fully paid">
                                                    <i class="bi bi-check2-all"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-success small"><i class="bi bi-check-circle me-1"></i>Settled</span>
                                    }
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@p.Id"
                                          class="d-inline ms-1"
                                          onsubmit="return confirm('Delete this payable?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
                @if (Model.Payables.Any() && Model.Payables.Any(p => p.Status != PayableStatus.Paid))
                {
                    <tfoot>
                        <tr class="report-total-row">
                            <td colspan="6" class="text-end"><strong>Total Pending</strong></td>
                            <td class="text-end fw-bold" style="color:var(--danger)">
                                Rs. @Model.Payables.Sum(p => p.PendingAmount).ToString("N2")
                            </td>
                            <td colspan="2"></td>
                        </tr>
                    </tfoot>
                }
            </table>
        </div>
    </div>
</div>

<!-- Pay Modal -->
<div class="modal fade" id="payModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <form method="post" asp-page-handler="RecordPayment">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-cash me-2"></i>Record Payment</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="mb-2 fw-semibold" id="payModalSupplier"></p>
                    <input type="hidden" name="id" id="payModalId" />
                    <div class="mb-3">
                        <label class="form-label">Amount Paying (Rs.)</label>
                        <input type="number" class="form-control" name="amount" id="payModalAmount"
                               step="0.01" min="0.01" required />
                        <div class="form-text" id="payModalPendingHint"></div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success btn-sm">
                        <i class="bi bi-check-circle me-1"></i>Confirm Payment
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const payModal = document.getElementById('payModal');
    payModal.addEventListener('show.bs.modal', e => {
        const btn = e.relatedTarget;
        document.getElementById('payModalId').value = btn.dataset.id;
        document.getElementById('payModalSupplier').textContent = btn.dataset.name;
        const pending = parseFloat(btn.dataset.pending);
        document.getElementById('payModalAmount').value = pending.toFixed(2);
        document.getElementById('payModalAmount').max = pending;
        document.getElementById('payModalPendingHint').textContent = `Pending: Rs. ${pending.toFixed(2)}`;
    });
</script>
}
