@page
@using PrimeRx.Models
@model PrimeRx.Pages.Admin.Expenses.CreateModel
@{
    ViewData["Title"] = "Add Expense";
}

<h2 class="mb-3">Add Expense</h2>

<div class="card shadow-sm col-lg-8">
    <div class="card-body">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Expense.Category" class="form-label">Category</label>
                    <select asp-for="Expense.Category" class="form-select">
                        @foreach (var c in ExpenseCategories.All)
                        {
                            <option value="@c">@ExpenseCategories.Display(c)</option>
                        }
                    </select>
                </div>
                <div class="col-md-6">
                    <label asp-for="Expense.Amount" class="form-label">Amount (Rs.)</label>
                    <input asp-for="Expense.Amount" class="form-control" type="number" step="0.01" min="0.01" required />
                    <span asp-validation-for="Expense.Amount" class="text-danger"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="Expense.ExpenseDate" class="form-label">Expense Date</label>
                    <input asp-for="Expense.ExpenseDate" class="form-control" type="date" />
                </div>
                <div class="col-md-6">
                    <label asp-for="Expense.StaffId" class="form-label">Staff (optional)</label>
                    <select asp-for="Expense.StaffId" class="form-select">
                        <option value="">— None —</option>
                        @foreach (var email in Model.StaffEmails)
                        {
                            <option value="@email">@email</option>
                        }
                    </select>
                    <div class="form-text">Link a salary/expense to a staff member.</div>
                </div>
                <div class="col-12">
                    <label asp-for="Expense.Reason" class="form-label">Reason / Description</label>
                    <textarea asp-for="Expense.Reason" class="form-control" rows="2" placeholder="e.g. Rent, Electricity, Bonus, Medicine purchase from XYZ"></textarea>
                </div>
                <div class="col-12">
                    <label asp-for="Expense.Notes" class="form-label">Notes (optional)</label>
                    <input asp-for="Expense.Notes" class="form-control" />
                </div>
            </div>
            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Save Expense</button>
                <a asp-page="/Admin/Expenses/Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
