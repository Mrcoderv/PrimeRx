@page
@model PrimeRx.Pages.Admin.MedicineMaster.IndexModel
@{
    ViewData["Title"] = "Medicine Master List";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div>
        <h1 class="page-title"><i class="bi bi-capsule me-2"></i>Medicine Master List</h1>
        <p class="page-subtitle mb-0">Pure catalog — generic names, brands, forms, and storage info. No prices or quantities.</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-page="Create" class="btn btn-accent">
            <i class="bi bi-plus-lg me-1"></i>Add New
        </a>
        <button type="button" class="btn btn-accent" data-bs-toggle="modal" data-bs-target="#importModal">
            <i class="bi bi-upload me-1"></i>Import
        </button>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert @(Model.IsError ? "alert-danger" : "alert-success") alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Search & Filter -->
<form method="get" class="row g-2 mb-3 align-items-end">
    <div class="col-md-5">
        <label for="search" class="form-label small mb-1">Search</label>
        <input type="text" id="search" name="search" value="@Model.Search"
               class="form-control" placeholder="Search by generic name, brand, manufacturer, category…" />
    </div>
    <div class="col-auto d-flex align-items-end gap-2">
        <button type="submit" class="btn btn-accent"><i class="bi bi-search me-1"></i>Search</button>
        <a asp-page="Index" class="btn btn-outline-secondary">Clear</a>
    </div>
</form>

<!-- Alphabet Toggle -->
<div class="mb-3">
    <div class="d-flex flex-wrap gap-1">
        <a asp-page="Index" asp-route-search="@Model.Search"
           class="btn btn-sm @(string.IsNullOrEmpty(Model.Letter) ? "btn-accent" : "btn-outline-secondary")">
            All
        </a>
        @for (char c = 'A'; c <= 'Z'; c++)
        {
            <a asp-page="Index" asp-route-letter="@c.ToString()" asp-route-search="@Model.Search"
               class="btn btn-sm @(Model.Letter?.Equals(c.ToString(), StringComparison.OrdinalIgnoreCase) == true ? "btn-accent" : "btn-outline-secondary")">
                @c
            </a>
        }
    </div>
</div>

<!-- Master List Table (NO price, NO quantity) -->
<div class="panel-card">
    <div class="panel-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            Showing @Model.Masters.Count of @Model.TotalCount medicines
            @if (!string.IsNullOrEmpty(Model.Letter))
            {
                <span class="text-muted"> (starting with '@Model.Letter.ToUpper()')</span>
            }
        </h5>
    </div>
    <div class="p-0 panel-body-flush">
        <div class="table-responsive">
            <table class="table table-pro mb-0">
                <thead>
                    <tr>
                        <th>Generic Name</th>
                        <th>Brand Name</th>
                        <th>Manufacturer</th>
                        <th>Form</th>
                        <th>Strength</th>
                        <th>Unit</th>
                        <th>Category</th>
                        <th style="width:90px">Stock</th>
                        <th style="width:100px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in Model.Masters)
                    {
                        <tr class="@(m.IsActive ? "" : "text-muted")">
                            <td><strong>@m.GenericName</strong></td>
                            <td>@(m.BrandName ?? "—")</td>
                            <td>@(m.Manufacturer ?? "—")</td>
                            <td>@(m.Form ?? "—")</td>
                            <td>@(m.Strength ?? "—")</td>
                            <td>@(m.Unit ?? "—")</td>
                            <td><span class="badge bg-secondary bg-opacity-50">@(m.Category ?? "—")</span></td>
                            <td class="text-center">
                                @if (Model.GenericNamesInStock.Contains(m.GenericName.ToLower()))
                                {
                                    <span class="badge bg-success bg-opacity-75"><i class="bi bi-check-circle me-1"></i>In Stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary bg-opacity-25 text-muted">—</span>
                                }
                            </td>
                            <td>
                                <a asp-page="Edit" asp-route-id="@m.Id" class="btn btn-sm btn-outline-accent">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (!Model.Masters.Any())
{
    <div class="text-center text-muted mt-4 py-5">
        <i class="bi bi-capsule display-6 d-block mb-2" style="opacity:0.4"></i>
        No medicines in the master list.
        <a asp-page="Create" class="d-block mt-2">Add the first medicine</a>
    </div>
}

<!-- Import Modal -->
<div class="modal fade" id="importModal" tabindex="-1" @(Model.ShowImportModal ? "data-bs-backdrop=static data-bs-keyboard=false" : "")>
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" enctype="multipart/form-data" asp-page-handler="Import">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-upload me-2"></i>Import Medicine Master</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Upload Excel file (.xlsx or .csv)</label>
                        <input type="file" name="importFile" class="form-control" accept=".xlsx,.csv" required />
                    </div>
                    <div class="mb-3">
                        <div class="form-check">
                            <input type="checkbox" name="updateExisting" class="form-check-input" id="updateExisting" value="true" checked />
                            <label class="form-check-label" for="updateExisting">Update existing records (matched by Generic Name)</label>
                        </div>
                    </div>
                    <div class="small text-muted">
                        <strong>Supported formats:</strong><br />
                        <strong>Standard:</strong> Generic Name *, Brand Name, Manufacturer, Form, Strength, Unit, Category, HSN Code, Rack / Location<br />
                        <strong>Nepal 5K Database:</strong> S.No, Generic Name, Brand Name, Manufacturer, Company Type, Category, Strength/Form
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-accent">Import</button>
                </div>
            </form>
        </div>
    </div>
</div>

@if (Model.ShowImportModal)
{
    @section Scripts {
        <script>new bootstrap.Modal(document.getElementById('importModal')).show();</script>
    }
}
