@page
@model PrimeRx.Pages.Admin.Backup.IndexModel
@{
    ViewData["Title"] = "Backup & Restore";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Backup &amp; Restore</h1>
        <p class="page-subtitle">Protect your pharmacy data with regular backups</p>
    </div>
    <form method="post" asp-page-handler="Download">
        <button type="submit" class="btn btn-accent btn-lg">
            <i class="bi bi-download me-1"></i> Download Backup
        </button>
    </form>
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-@(Model.IsError ? "danger" : "success") alert-dismissible fade show">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row g-4">
    <!-- Create Backup -->
    <div class="col-lg-6">
        <div class="panel-card">
            <div class="panel-header">
                <h5><i class="bi bi-cloud-upload me-2"></i>Create Backup</h5>
            </div>
            <div class="panel-body">
                <p class="text-muted small mb-3">
                    Creates a timestamped copy of the database on this server.
                    Use <strong>Download Backup</strong> above to get a portable copy.
                </p>
                <form method="post" asp-page-handler="Create">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-hdd me-1"></i>Create Server Backup
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Restore from Upload -->
    <div class="col-lg-6">
        <div class="panel-card">
            <div class="panel-header">
                <h5><i class="bi bi-cloud-download me-2"></i>Restore from File</h5>
            </div>
            <div class="panel-body">
                <div class="alert alert-warning mb-3 small">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    <strong>Warning:</strong> Restoring will replace all current data. The system creates a safety copy before restoring.
                </div>
                <form method="post" asp-page-handler="Restore" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label">Select backup file (.db)</label>
                        <input type="file" name="backupFile" class="form-control" accept=".db" required />
                    </div>
                    <button type="submit" class="btn btn-warning"
                            onclick="return confirm('This will replace ALL current data. Are you sure?')">
                        <i class="bi bi-arrow-counterclockwise me-1"></i>Restore Database
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Saved Backups List -->
<div class="panel-card mt-4">
    <div class="panel-header d-flex justify-content-between align-items-center">
        <h5><i class="bi bi-folder2-open me-2"></i>Server Backups</h5>
        <span class="badge bg-secondary">@Model.Backups.Count saved</span>
    </div>
    <div class="table-responsive">
        <table class="table table-pro mb-0">
            <thead>
                <tr>
                    <th>File Name</th>
                    <th>Created</th>
                    <th>Size</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Backups.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">
                            No server backups yet. Click "Create Server Backup" to get started.
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var b in Model.Backups)
                    {
                        <tr>
                            <td><code>@b.FileName</code></td>
                            <td>@b.CreatedAt.ToString("dd-MM-yyyy HH:mm")</td>
                            <td>@b.SizeDisplay</td>
                            <td class="text-end">
                                <form method="post" asp-page-handler="RestoreFromServer" class="d-inline">
                                    <input type="hidden" name="filePath" value="@b.FullPath" />
                                    <button type="submit" class="btn btn-sm btn-outline-warning"
                                            onclick="return confirm('Restore from @b.FileName? Current data will be replaced.')">
                                        <i class="bi bi-arrow-counterclockwise"></i> Restore
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
