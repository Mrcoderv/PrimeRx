@page
@model PrimeRx.Pages.Admin.Suppliers.AddModel
@{
    ViewData["Title"] = "Add Supplier";
}

<div class="page-header mb-3">
    <div>
        <h1 class="page-title">Add Supplier</h1>
        <p class="page-subtitle">Register a new pharmaceutical supplier or distributor</p>
    </div>
    <a asp-page="/Admin/Suppliers/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="panel-card mb-3">
                <div class="panel-header">Basic Information</div>
                <div class="panel-body">
                    <div class="mb-3">
                        <label asp-for="Input.Name" class="form-label"></label>
                        <input asp-for="Input.Name" class="form-control" placeholder="e.g. ABC Pharma Distributors" autofocus />
                        <span asp-validation-for="Input.Name" class="text-danger small"></span>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Input.ContactPerson" class="form-label"></label>
                            <input asp-for="Input.ContactPerson" class="form-control" placeholder="Sales representative name" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.Phone" class="form-label">Phone</label>
                            <input asp-for="Input.Phone" class="form-control" placeholder="e.g. 9841000000" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <input asp-for="Input.Email" class="form-control" type="email" placeholder="supplier@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Address" class="form-label">Address</label>
                        <textarea asp-for="Input.Address" class="form-control" rows="2" placeholder="Full address…"></textarea>
                    </div>
                </div>
            </div>

            <div class="panel-card">
                <div class="panel-header">Business Details</div>
                <div class="panel-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Input.PAN" class="form-label"></label>
                            <input asp-for="Input.PAN" class="form-control" placeholder="PAN number" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.DdaRegNo" class="form-label"></label>
                            <input asp-for="Input.DdaRegNo" class="form-control" placeholder="DDA registration number" />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Input.CreditDays" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="Input.CreditDays" class="form-control" type="number" min="0" max="365" />
                                <span class="input-group-text">days</span>
                            </div>
                            <div class="form-text">Days before payment is due for credit purchases</div>
                        </div>
                        <div class="col-md-6 d-flex align-items-end pb-1">
                            <div class="form-check">
                                <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" checked />
                                <label asp-for="Input.IsActive" class="form-check-label">Active supplier</label>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Notes" class="form-label">Notes</label>
                        <textarea asp-for="Input.Notes" class="form-control" rows="2" placeholder="Any additional notes…"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="panel-card billing-sidebar">
                <div class="panel-header">Save</div>
                <div class="panel-body">
                    <p class="text-muted small mb-3">Fill in at least the supplier name, then save. You can edit other details later.</p>
                    <button type="submit" class="btn btn-accent btn-lg w-100">
                        <i class="bi bi-save me-1"></i>Save Supplier
                    </button>
                    <a asp-page="/Admin/Suppliers/Index" class="btn btn-outline-secondary w-100 mt-2">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
