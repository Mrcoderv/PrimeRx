@page "{id:int}"
@model PrimeRx.Pages.Admin.Suppliers.EditModel
@{
    ViewData["Title"] = "Edit Supplier";
}

<div class="page-header mb-3">
    <div>
        <h1 class="page-title">Edit Supplier</h1>
        <p class="page-subtitle">Update supplier details</p>
    </div>
    <a asp-page="/Admin/Suppliers/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
</div>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post">
    <input type="hidden" asp-for="Input.Id" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="panel-card mb-3">
                <div class="panel-header">Basic Information</div>
                <div class="panel-body">
                    <div class="mb-3">
                        <label asp-for="Input.Name" class="form-label"></label>
                        <input asp-for="Input.Name" class="form-control" />
                        <span asp-validation-for="Input.Name" class="text-danger small"></span>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Input.ContactPerson" class="form-label"></label>
                            <input asp-for="Input.ContactPerson" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.Phone" class="form-label">Phone</label>
                            <input asp-for="Input.Phone" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Email" class="form-label">Email</label>
                        <input asp-for="Input.Email" class="form-control" type="email" />
                        <span asp-validation-for="Input.Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Address" class="form-label">Address</label>
                        <textarea asp-for="Input.Address" class="form-control" rows="2"></textarea>
                    </div>
                </div>
            </div>

            <div class="panel-card">
                <div class="panel-header">Business Details</div>
                <div class="panel-body">
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Input.PAN" class="form-label"></label>
                            <input asp-for="Input.PAN" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.DdaRegNo" class="form-label"></label>
                            <input asp-for="Input.DdaRegNo" class="form-control" />
                        </div>
                    </div>
                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="Input.CreditDays" class="form-label"></label>
                            <div class="input-group">
                                <input asp-for="Input.CreditDays" class="form-control" type="number" min="0" max="365" />
                                <span class="input-group-text">days</span>
                            </div>
                        </div>
                        <div class="col-md-6 d-flex align-items-end pb-1">
                            <div class="form-check">
                                <input asp-for="Input.IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="Input.IsActive" class="form-check-label">Active supplier</label>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.Notes" class="form-label">Notes</label>
                        <textarea asp-for="Input.Notes" class="form-control" rows="2"></textarea>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="panel-card billing-sidebar">
                <div class="panel-header">Save Changes</div>
                <div class="panel-body">
                    <button type="submit" class="btn btn-accent btn-lg w-100">
                        <i class="bi bi-save me-1"></i>Update Supplier
                    </button>
                    <a asp-page="/Admin/Suppliers/Index" class="btn btn-outline-secondary w-100 mt-2">Cancel</a>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
