@page
@model WebApplication1.Pages.Reports.IndexModel
@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Reports & Analytics</h1>
        <p class="page-subtitle">Sales diagrams, exports, and business intelligence</p>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="panel-card h-100">
            <div class="panel-header"><h5><i class="bi bi-graph-up me-2"></i>Monthly Sales Diagram (Last 30 Days)</h5></div>
            <div class="panel-body chart-container">
                <canvas id="monthlySalesChart" height="100"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="panel-card h-100">
            <div class="panel-header"><h5><i class="bi bi-pie-chart me-2"></i>Top Selling Medicines</h5></div>
            <div class="panel-body chart-container">
                <canvas id="medicinePieChart" height="200"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="report-tile">
            <h5><i class="bi bi-calendar-day me-2"></i>Daily Sales</h5>
            <form method="get" asp-page-handler="DailySales">
                <input type="date" name="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control mb-2" />
                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit" name="format" value="view" class="btn btn-sm btn-accent">View</button>
                    <button type="submit" name="format" value="pdf" class="btn btn-sm btn-outline-accent">PDF</button>
                    <button type="submit" name="format" value="excel" class="btn btn-sm btn-outline-accent">Excel</button>
                </div>
            </form>
        </div>
    </div>
    <div class="col-md-4">
        <div class="report-tile">
            <h5><i class="bi bi-calendar-month me-2"></i>Monthly Sales</h5>
            <form method="get" asp-page-handler="MonthlySales">
                <div class="row g-2 mb-2">
                    <div class="col-6"><input type="number" name="year" value="@DateTime.Today.Year" class="form-control" /></div>
                    <div class="col-6"><input type="number" name="month" value="@DateTime.Today.Month" class="form-control" min="1" max="12" /></div>
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit" name="format" value="view" class="btn btn-sm btn-accent">View</button>
                    <button type="submit" name="format" value="pdf" class="btn btn-sm btn-outline-accent">PDF</button>
                    <button type="submit" name="format" value="excel" class="btn btn-sm btn-outline-accent">Excel</button>
                </div>
            </form>
        </div>
    </div>
    <div class="col-md-4">
        <div class="report-tile">
            <h5><i class="bi bi-capsule me-2"></i>Medicine-wise Sales</h5>
            <form method="get" asp-page-handler="MedicineSales">
                <div class="d-flex gap-2 flex-wrap">
                    <button type="submit" name="format" value="view" class="btn btn-sm btn-accent">View</button>
                    <button type="submit" name="format" value="excel" class="btn btn-sm btn-outline-accent">Excel</button>
                </div>
            </form>
        </div>
    </div>
    <div class="col-md-4">
        <div class="report-tile">
            <h5><i class="bi bi-currency-rupee me-2"></i>Profit & Loss</h5>
            <a asp-page-handler="ProfitLoss" class="btn btn-sm btn-accent">View Report</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="report-tile">
            <h5><i class="bi bi-wallet2 me-2"></i>Due Collection</h5>
            <a asp-page-handler="DueCollection" class="btn btn-sm btn-accent">View Report</a>
        </div>
    </div>
    <div class="col-md-4">
        <div class="report-tile">
            <h5><i class="bi bi-box-seam me-2"></i>Inventory Report</h5>
            <div class="d-flex gap-2">
                <a asp-page-handler="Inventory" class="btn btn-sm btn-accent">View</a>
                <a asp-page-handler="Inventory" asp-route-format="excel" class="btn btn-sm btn-outline-accent">Excel</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="report-tile">
            <h5><i class="bi bi-exclamation-triangle me-2"></i>Expiry Report</h5>
            <a asp-page-handler="Expiry" class="btn btn-sm btn-accent">View Report</a>
        </div>
    </div>
</div>

@if (Model.ReportTitle != null)
{
    <div class="panel-card mt-2">
        <div class="panel-header d-flex justify-content-between align-items-center">
            <h5>@Model.ReportTitle</h5>
            @if (Model.SummaryText != null)
            {
                <strong class="text-info">@Model.SummaryText</strong>
            }
        </div>
        <div class="p-0">
            @if (Model.SalesReport != null)
            {
                <div class="table-responsive">
                    <table class="table table-pro mb-0">
                        <thead><tr><th>Bill #</th><th>Date</th><th>Customer</th><th>Amount</th><th>Status</th></tr></thead>
                        <tbody>
                            @foreach (var b in Model.SalesReport.Bills)
                            {
                                <tr>
                                    <td>@b.BillNumber</td>
                                    <td>@b.BillDate.ToString("dd-MM-yyyy")</td>
                                    <td>@b.CustomerName</td>
                                    <td>Rs. @b.FinalAmount.ToString("N2")</td>
                                    <td>@b.PaymentStatus</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            @if (Model.MedicineSales != null)
            {
                <div class="table-responsive">
                    <table class="table table-pro mb-0">
                        <thead><tr><th>Medicine</th><th>Qty</th><th>Amount</th></tr></thead>
                        <tbody>
                            @foreach (var r in Model.MedicineSales)
                            {
                                <tr>
                                    <td>@r.MedicineName</td>
                                    <td>@r.TotalQuantity</td>
                                    <td>Rs. @r.TotalAmount.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            @if (Model.ProfitLoss != null)
            {
                <div class="panel-body">
                    <p>Revenue: <strong>Rs. @Model.ProfitLoss.Revenue.ToString("N2")</strong></p>
                    <p>Cost: <strong>Rs. @Model.ProfitLoss.Cost.ToString("N2")</strong></p>
                    <p>Profit: <strong class="@(Model.ProfitLoss.Profit >= 0 ? "text-success" : "text-danger")">Rs. @Model.ProfitLoss.Profit.ToString("N2")</strong></p>
                    <p>Bills: @Model.ProfitLoss.BillCount</p>
                </div>
            }
            @if (Model.DueReport != null)
            {
                <div class="panel-body">
                    <p>Collected: <strong>Rs. @Model.DueReport.TotalCollected.ToString("N2")</strong></p>
                    <p>Outstanding: <strong class="text-danger">Rs. @Model.DueReport.OutstandingDue.ToString("N2")</strong></p>
                </div>
            }
            @if (Model.InventoryMedicines != null)
            {
                <div class="table-responsive">
                    <table class="table table-pro mb-0">
                        <thead><tr><th>Medicine</th><th>Stock</th><th>MRP</th><th>Expiry</th></tr></thead>
                        <tbody>
                            @foreach (var m in Model.InventoryMedicines)
                            {
                                <tr>
                                    <td>@m.Name</td>
                                    <td>@m.StockQuantity</td>
                                    <td>Rs. @m.MRP.ToString("N2")</td>
                                    <td>@(m.ExpiryDate?.ToString("dd-MM-yyyy") ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            @if (Model.ExpiryMedicines != null)
            {
                <div class="table-responsive">
                    <table class="table table-pro mb-0">
                        <thead><tr><th>Medicine</th><th>Stock</th><th>Expiry</th></tr></thead>
                        <tbody>
                            @foreach (var m in Model.ExpiryMedicines)
                            {
                                <tr>
                                    <td>@m.Name</td>
                                    <td>@m.StockQuantity</td>
                                    <td class="text-danger">@m.ExpiryDate?.ToString("dd-MM-yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        const salesTrend = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.SalesTrend));
        const topMeds = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MedicineSalesChart));

        new Chart(document.getElementById('monthlySalesChart'), {
            type: 'bar',
            data: {
                labels: salesTrend.map(x => x.label),
                datasets: [{
                    label: 'Daily Sales (Rs.)',
                    data: salesTrend.map(x => x.amount),
                    backgroundColor: 'rgba(56, 189, 248, 0.7)',
                    borderColor: '#38bdf8',
                    borderWidth: 1,
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { labels: { color: '#cbd5e1' } } },
                scales: {
                    y: { beginAtZero: true, ticks: { color: '#94a3b8' }, grid: { color: 'rgba(255,255,255,0.08)' } },
                    x: { ticks: { color: '#94a3b8', maxRotation: 45 }, grid: { display: false } }
                }
            }
        });

        new Chart(document.getElementById('medicinePieChart'), {
            type: 'pie',
            data: {
                labels: topMeds.slice(0, 8).map(x => x.medicineName),
                datasets: [{
                    data: topMeds.slice(0, 8).map(x => x.totalAmount),
                    backgroundColor: ['#3b82f6','#06b6d4','#6366f1','#8b5cf6','#0ea5e9','#14b8a6','#f59e0b','#ef4444']
                }]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom', labels: { color: '#cbd5e1', boxWidth: 10, font: { size: 10 } } } }
            }
        });
    </script>
}
