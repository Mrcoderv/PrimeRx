@page
@model WebApplication1.Pages.Inventory.AdjustModel
@{
    ViewData["Title"] = "Stock Adjustment";
}

<h2 class="mb-3">Stock Adjustment</h2>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-success">@Model.Message</div>
}
@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="card shadow-sm col-lg-6">
    <div class="card-body">
        <p class="text-muted">Use positive numbers to add stock, negative to remove (e.g. damage/loss).</p>
        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.MedicineId" class="form-label">Medicine</label>
                <select asp-for="Input.MedicineId" class="form-select" asp-items="Model.MedicineOptions"></select>
            </div>
            <div class="mb-3">
                <label asp-for="Input.QuantityChange" class="form-label">Quantity Change</label>
                <input asp-for="Input.QuantityChange" class="form-control" type="number" />
            </div>
            <div class="mb-3">
                <label asp-for="Input.Reference" class="form-label">Reason</label>
                <input asp-for="Input.Reference" class="form-control" />
            </div>
            <button type="submit" class="btn btn-warning">Adjust Stock</button>
            <a asp-page="/Inventory/Index" class="btn btn-outline-secondary">Back</a>
        </form>
    </div>
</div>
