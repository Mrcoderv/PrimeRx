@page
@model WebApplication1.Pages.Inventory.HistoryModel
@{
    ViewData["Title"] = "Inventory History";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Inventory Transaction History</h2>
    <a asp-page="/Inventory/Index" class="btn btn-outline-secondary btn-sm">Back</a>
</div>

<div class="table-responsive card shadow-sm">
    <table class="table table-hover mb-0">
        <thead class="table-light">
            <tr>
                <th>Date</th>
                <th>Medicine</th>
                <th>Type</th>
                <th>Change</th>
                <th>Reference</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model.Transactions)
            {
                <tr>
                    <td>@t.TransactionDate.ToString("dd-MM-yyyy HH:mm")</td>
                    <td>@t.Medicine.Name</td>
                    <td><span class="badge bg-secondary">@t.TransactionType</span></td>
                    <td class="@(t.QuantityChange > 0 ? "text-success" : "text-danger")">@t.QuantityChange.ToString("+0;-#")</td>
                    <td>@t.Reference</td>
                </tr>
            }
        </tbody>
    </table>
</div>
