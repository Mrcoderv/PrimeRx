@page
@model WebApplication1.Pages.Setup.IndexModel
@{
    ViewData["Title"] = "Initial Setup";
    Layout = "_Layout";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">PrimeRx - First Time Setup</h4>
            </div>
            <div class="card-body">
                <p class="text-muted">Configure your pharmacy and create the administrator account.</p>

                @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                {
                    <div class="alert alert-danger">@Model.ErrorMessage</div>
                }

                <form method="post">
                    <h5 class="mt-3">Company Information</h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Input.CompanyName" class="form-label"></label>
                            <input asp-for="Input.CompanyName" class="form-control" />
                            <span asp-validation-for="Input.CompanyName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.Phone" class="form-label"></label>
                            <input asp-for="Input.Phone" class="form-control" />
                            <span asp-validation-for="Input.Phone" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Input.Address" class="form-label"></label>
                            <textarea asp-for="Input.Address" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.PAN" class="form-label"></label>
                            <input asp-for="Input.PAN" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.GSTIN" class="form-label"></label>
                            <input asp-for="Input.GSTIN" class="form-control" />
                        </div>
                    </div>

                    <h5 class="mt-4">Administrator Account</h5>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="Input.AdminEmail" class="form-label"></label>
                            <input asp-for="Input.AdminEmail" class="form-control" />
                            <span asp-validation-for="Input.AdminEmail" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Input.AdminPassword" class="form-label"></label>
                            <input asp-for="Input.AdminPassword" class="form-control" type="password" />
                            <span asp-validation-for="Input.AdminPassword" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-check mt-3">
                        <input asp-for="Input.SeedMedicines" class="form-check-input" />
                        <label asp-for="Input.SeedMedicines" class="form-check-label">Load sample medicine database</label>
                    </div>

                    <button type="submit" class="btn btn-primary btn-lg mt-4 w-100">Complete Setup</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
