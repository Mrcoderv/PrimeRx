@page
@model WebApplication1.Pages.Billing.IndexModel
@{
    ViewData["Title"] = "New Bill";
}

<div class="billing-page">
    <div class="page-header">
        <div>
            <h1 class="page-title">Point of Sale</h1>
            <p class="page-subtitle">Fast billing with medicine search and invoice generation</p>
        </div>
        <a asp-page="/Billing/History" class="btn btn-outline-accent">Bill History</a>
    </div>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success alert-dismissible fade show">
            @Model.SuccessMessage
            @if (Model.LastBillId.HasValue)
            {
                <a asp-page-handler="DownloadPdf" asp-route-billId="@Model.LastBillId" class="btn btn-sm btn-success ms-2">Download PDF</a>
            }
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    <form method="post" id="billingForm">
        <div class="row g-3">
            <div class="col-lg-8">
                <div class="card shadow-sm mb-3 panel-card">
                    <div class="card-body">
                        <label class="form-label fw-semibold">Search Medicine</label>
                        <select id="medicineSearch" placeholder="Type to search medicines..."></select>
                    </div>
                </div>

                <div class="panel-card">
                    <div class="panel-header">Bill Items</div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0" id="itemsTable">
                            <thead class="table-light">
                                <tr>
                                    <th>Medicine</th>
                                    <th style="width:100px">Rate</th>
                                    <th style="width:80px">Qty</th>
                                    <th style="width:90px">Disc/Item</th>
                                    <th style="width:100px">Amount</th>
                                    <th style="width:50px"></th>
                                </tr>
                            </thead>
                            <tbody id="itemsBody">
                                <tr id="emptyRow">
                                    <td colspan="6" class="text-center text-muted py-4">Search and add medicines above</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="panel-card billing-sidebar">
                    <div class="panel-header">Customer & Payment</div>
                    <div class="panel-body">
                        <div class="mb-3">
                            <label asp-for="Input.CustomerName" class="form-label"></label>
                            <input asp-for="Input.CustomerName" class="form-control" id="customerName" />
                            <span asp-validation-for="Input.CustomerName" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.CustomerPhone" class="form-label"></label>
                            <input asp-for="Input.CustomerPhone" class="form-control" id="customerPhone" />
                            <span asp-validation-for="Input.CustomerPhone" class="text-danger"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.PaymentMethod" class="form-label"></label>
                            <select asp-for="Input.PaymentMethod" class="form-select" id="paymentMethod">
                                <option value="Cash">Cash</option>
                                <option value="Online">Online / Card</option>
                                <option value="Due">Due</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Input.DiscountAmount" class="form-label"></label>
                            <input asp-for="Input.DiscountAmount" class="form-control" id="billDiscount" type="number" step="0.01" min="0" value="0" />
                        </div>

                        <hr />
                        <div class="d-flex justify-content-between"><span>Subtotal</span><span id="subtotalDisplay">0.00</span></div>
                        <div class="d-flex justify-content-between"><span>Discount</span><span id="discountDisplay">0.00</span></div>
                        <div class="d-flex justify-content-between fw-bold fs-5 mt-2"><span>Total</span><span id="totalDisplay">0.00</span></div>

                        <input type="hidden" asp-for="Input.ItemsJson" id="itemsJson" />
                        <button type="submit" class="btn btn-accent btn-lg w-100 mt-3" id="generateBtn" disabled>Generate Bill</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Styles {
    <link href="https://cdn.jsdelivr.net/npm/tom-select@2.4.1/dist/css/tom-select.bootstrap5.min.css" rel="stylesheet" />
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/tom-select@2.4.1/dist/js/tom-select.complete.min.js"></script>
    <script src="~/js/billing.js" asp-append-version="true"></script>
}
