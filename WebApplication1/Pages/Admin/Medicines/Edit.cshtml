@page "{id:int}"
@model WebApplication1.Pages.Admin.Medicines.EditModel
@{
    ViewData["Title"] = "Edit Medicine";
}

<h2 class="mb-3">Edit Medicine</h2>

<div class="card shadow-sm col-lg-8">
    <div class="card-body">
        <form method="post">
            <input type="hidden" asp-for="Medicine.Id" />
            <partial name="_MedicineForm" model="Model.Medicine" />
            <button type="submit" class="btn btn-primary">Update</button>
            <a asp-page="/Admin/Medicines/Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
